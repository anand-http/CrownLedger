    <script type="text/javascript">
        var MyIp = '';
        function functiontab(ctrl) {
            $(ctrl).parent('li').siblings('li').removeClass('active');
            $(ctrl).parent('li').addClass('active');
            var id = $(ctrl).attr('href').replace('#', '');
            $(ctrl).parents('ul#myTabs').next().find('div.tab-pane').each(function (i, n) {
                if ($(this).attr('id') == id) {
                    $(this).addClass('active in');
                    $('html,body').animate({
                        scrollTop: $(this).offset().top - 70
                    }, 500);
                }
                else {
                    $(this).removeClass('active in');
                }
            })
        }
        $(document).ready(function () {
            //$('.btnskip').remove();
            //$('.btnskip2').remove();
            $("#btnlogin").parent().on('hover', function () {
                $(this).addClass('.tooltipwrap');
            });
            $(".closeicon").click(function () {
                $(this).parents('.tab-pane').removeClass('active in');
            });
            $('.input-checkbox100').on('change', function () {
                if ($(this).is(':checked')) {
                    $("#btnlogin").removeClass('disabled');
                    $("#btnlogin").parent().removeClass('tooltipwrap');
                    $('#btnlogin1').removeAttr('disabled');
                    $('#btnlogin1').removeClass('btnLogin');
                }
                else {
                    $("#btnlogin").addClass('disabled');
                    $("#btnlogin").parent().addClass('tooltipwrap');
                    $('#btnlogin1').attr('disabled', 'disabled');
                    $('#btnlogin1').addClass('btnLogin');
                }
            });

            //$("#btnlogin").on('click', CheckLogin_Click);
            $("#txtUserName, #txtPassword").keydown(function (event) {
                if (event.keyCode == 13) {
                    $("#btnlogin").click();
                }
            });
            if ($(window).width() < 767) {
                $('.page-content', window.parent.document).attr('style', 'height:' + (parseInt($(window).height())).toString() + 'px;');
            }
            $('#txtUserName').focus(function () {
                $('.tooltip').attr('style', 'top:-42px;left:49px;display:none;');
            });
            $('#txtEntityCode').focus(function () {
                $('.tooltip').attr('style', 'top:-42px;left:49px;display:none;');
            });

            $.getJSON("https://api.ipify.org/?format=json", function (e) {
                MyIp = e.ip;
            });
            if ($('#PasswordComplexityModel').length > 0) {
                $('#PasswordComplexityModel').modal('show');
            }
        });
        function requiredFieldsforLogin(cfld, cmsg, minSize) {
            /********** to replace ************/
            cfld.off('click');
            cfld.on('click', function () { cfld.bstooltip('hide'); });
            cfld.off('keypress keyup');
            cfld.on('keypress keyup change', function () {
                if (minSize == 0 || cfld.val().trim().length >= minSize) {
                    cfld.parent('div.validate-input').removeClass('alert-validate');
                    cfld.parent('div.validate-input').attr('data-validate', '');
                }
                else {
                    cfld.parent('div.validate-input').addClass('alert-validate');
                    cfld.parent('div.validate-input').attr('data-validate', cmsg);
                    $('.submit-main').css('display', 'inline-block');
                    $('.submit-loader').hide();
                }
            });
            /********** to replace ************/
            if (cfld === "undefined") {
                alert('field is not defined');
                return false;
            }
            if (typeof minSize === "undefined" || minSize == undefined) {
                minSize = 0;
            }
            var value = cfld.val().trim();
            cfld.val(value);
            if (value.length > 0) {
                if (minSize == 0 || value.length >= minSize) {
                    cfld.parent('div.validate-input').removeClass('alert-validate');
                    cfld.parent('div.validate-input').attr('data-validate', '');
                    return true;
                }
                else {
                    cfld.parent('div.validate-input').addClass('alert-validate');
                    cfld.parent('div.validate-input').attr('data-validate', cmsg);
                    $('.submit-main').css('display', 'inline-block');
                    $('.submit-loader').hide();
                    return false;
                }
            }
            else {
                cfld.parent('div.validate-input').addClass('alert-validate');
                cfld.parent('div.validate-input').attr('data-validate', cmsg);
                $('.submit-main').css('display', 'inline-block');
                $('.submit-loader').hide();
                return false;
            }

        }

         //skip button

        //Login check go button
        function LoginCredentialcheck1() {

            $('.submit-main').hide();
            $('.submit-loader').css('display', 'inline-block');
            var validatemsg = requiredFieldsforLogin($('#txtUserName'), "User Name cannot left blank") &
                requiredFieldsforLogin($('#txtEntityCode'), "Entity Code cannot left blank") &
                requiredFieldsforLogin($('#txtPassword'), "Password cannot left blank");

            if (!validatemsg) {
                return false;
            }
            if (!$('.input-checkbox100').is(':checked')) {
                return false;
            }
            var credential = '';

            credential = {
                Type: 'U', Module: 'B', Domain: $('#txtEntityCode').val(), LoginID: $('#txtUserName').val(), Password: $('#txtPassword').val(), LanguageLocale: 'en-US', IpAddress: MyIp
            }

            $.ajax({
                url: "@Url.Action("LoginCredentialCheckOnly")",
                type: "POST",
                dataType: "json",
                data: { Credential: credential, ProductName: "Signature" },
                error: function (response) {
                    if (response.statusCode == 'LE001') {
                        var $Validate = [{ Code: response.StatusCode, Msg: 'Please enter valid User Name' }], $ctrls = [$('#txtUserName')];
                        swal({
                            title: '<h2>Error</h2>',
                            text: '<p>Please enter valid User Name</p>',
                            type: 'error',
                            html: true,
                            showCancelButton: false
                        });
                    }
                    else if (response.statusCode == 'LEEX1') {
                        var $Validate = [{ Code: response.StatusCode, Msg: 'Your password has been expired, Please contact to your administrator to reset the same.' }], $ctrls = [$('#txtUserName')];
                        swal({
                            title: '<h2>Error</h2>',
                            text: '<p>Your password has been expired, Please contact to your administrator to reset the same.</p>',
                            type: 'error',
                            html: true,
                            showCancelButton: false
                        });
                    }
                    else if (response.statusCode == 'LELK1') {
                        var $Validate = [{ Code: response.StatusCode, Msg: 'Your account has been locked, Please contact to your administrator to unlock it.' }], $ctrls = [$('#txtUserName')];
                        swal({
                            title: '<h2>Error</h2>',
                            text: '<p>Your account has been locked, Please contact to your administrator to unlock it.</p>',
                            type: 'error',
                            html: true,
                            showCancelButton: false
                        });
                    }
                    else if (response.statusCode == 'LE002') {
                        var $Validate = [{ Code: response.StatusCode, Msg: 'Please enter valid Password' }], $ctrls = [$('#txtPassword')];
                        swal({
                            title: '<h2>Error</h2>',
                            text: '<p>Please enter valid Password</p>',
                            type: 'error',
                            html: true,
                            showCancelButton: false
                        });
                        // swalAlertWithValidation(response.StatusCode, $ctrls, $Validate);
                    }
                    else if (response.statusCode == 'LE003') {
                        var $Validate = [{ Code: response.StatusCode, Msg: 'User Name is disabled. Please check with Administrator' }], $ctrls = [$('#txtUserName')];
                        swal({
                            title: '<h2>Error</h2>',
                            text: '<p>User Name is disabled. Please check with Administrator</p>',
                            type: 'error',
                            html: true,
                            showCancelButton: false
                        });
                    }
                    else {
                        var $Validate = [{ Code: 'LE001', Msg: 'Entity Code is not valid. Please check with Administrator' }], $ctrls = [$('#txtEntityCode')];
                        swal({
                            title: '<h2>Error</h2>',
                            text: '<p>Entity Code is not valid. Please check with Administrator</p>',
                            type: 'error',
                            html: true,
                            showCancelButton: false
                        });
                    }
                    $('.submit-main').css('display', 'inline-block');
                    $('.submit-loader').hide();
                },
                beforeSend: function () {
                    //$(".loginloading").show();
                    $("#btnlogin1").hide();
                    $(".dvlogincodecheck").hide();
                },
                success: function (data) {
                    if (data.SrvStatus == 'LE001') {
                        swal({
                            title: '<h2>Error</h2>',
                            text: '<p>Please enter valid User Name</p>',
                            type: 'error',
                            html: true,
                            showCancelButton: false
                        });
                        $("#btnlogin1").show();
                        $(".submit-loader").hide();
                    }
                    else if (data.SrvStatus == 'LEEX1') {
                        var $Validate = [{ Code: response.StatusCode, Msg: 'Your password has been expired, Please contact to your administrator to reset the same.' }], $ctrls = [$('#txtUserName')];
                        swal({
                            title: '<h2>Error</h2>',
                            text: '<p>Your password has been expired, Please contact to your administrator to reset the same.</p>',
                            type: 'error',
                            html: true,
                            showCancelButton: false
                        });
                    }
                    else if (data.SrvStatus == 'LELK1') {
                        var $Validate = [{ Code: response.StatusCode, Msg: 'Your account has been locked, Please contact to your administrator to unlock it.' }], $ctrls = [$('#txtUserName')];
                        swal({
                            title: '<h2>Error</h2>',
                            text: '<p>Your account has been locked, Please contact to your administrator to unlock it.</p>',
                            type: 'error',
                            html: true,
                            showCancelButton: false
                        });
                    }
                    else if (data.SrvStatus == 'LE002') {
                        swal({
                            title: '<h2>Error</h2>',
                            text: '<p>Please enter valid Password</p>',
                            type: 'error',
                            html: true,
                            showCancelButton: false
                        });
                        $("#btnlogin1").show();
                        $(".submit-loader").hide();
                    }
                    else if (data.SrvStatus == 'LE003') {
                        swal({
                            title: '<h2>Error</h2>',
                            text: '<p>User Name is disabled. Please check with Administrator</p>',
                            type: 'error',
                            html: true,
                            showCancelButton: false
                        });
                        $("#btnlogin1").show();
                        $(".submit-loader").hide();
                    }
                    else if (data.SrvStatus == "openQRCode") {
                        $(".dvlogincodecheck").hide();
                        $(".dvloginskipbutton").hide();
                        $(".imgqrcode").attr('src', data.QrImage);
                        $('#QrCodeModel').modal('show');
                        $('.Skip2FADate').text(data.Skip2FADate);
                        $(".dvlogincodecheckbtn").hide();
                    }
                    else if (data.SrvStatus == "openWQRCode") {
                        $(".dvlogincodecheck").hide();
                        $(".dvloginskipbutton").hide();
                        $(".imgqrcode").attr('src', data.QrImage);
                        $('#QrCodeModel').modal('show');
                        $('.Skip2FADate').text(data.Skip2FADate);
                        $(".dvlogincodecheckbtn").hide();
                        $('.btnskip').remove();
                        $('.btnskip2').remove();

                    }
                    else if (data.SrvStatus == "opencodediv") {
                        $('.logindomainform').hide();
                        $(".dvlogincodecheck").show();
                        $(".dvlogincodecheckbtn").show();
                        $(".dvloginskipbutton").show();
                        $('.Skip2FADatebottom').text(data.Skip2FADate);
                    }
                    else if (data.SrvStatus == "openWcodediv") {
                        $('.logindomainform').hide();
                        $(".dvlogincodecheck").show();
                        $(".dvlogincodecheckbtn").show();
