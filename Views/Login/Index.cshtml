                                        $('.dvlicencepaymentdetail').hide();
                                    }
                                });
                            $('.submit-main').css('display', 'inline-block');
                            $('.submit-loader').hide();
                        }
                        else {

                            if (status == 'Entity') {
                                window.location.href = "@Url.Action("EntityCheck")";
                            }

                            else if (status == 'Dashboard') {

                                if (readCookie("Pin") != null) {
                                    if (readCookie("Pin") == 'PersonalDashboard') {
