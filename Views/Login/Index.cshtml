                var validatemsg = requiredFieldsforLogin($('#txtOTP'), "Please enter otp")
                if (!validatemsg) {
                    return false;
                }
                var datatopost = {
                    Otp: $('#txtOTP').val(),
                };
                $.ajax({
                    url: "@Url.Action("EntityVerifyOtp")",
                    type: "POST",
                    dataType: "json",
                    data: datatopost,
                    error: function (response) {
                        swalValidationAlert('', 'error', response);
                    },
                    failure: function (response) {
                        swalValidationAlert('', 'error', response);
                    },
                    success: function (response) {
                        var data = response;
                        if (data == "OTP001") {
                            swal({
                                title: '<h2>Error</h2>',
                                text: '<p>Otp does not match</p>',
                                type: 'error',
                                html: true,
                                showCancelButton: false
                            });
                            return;
