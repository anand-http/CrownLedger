            $(ctrl).parents('ul#myTabs').next().find('div.tab-pane').each(function (i, n) {
                if ($(this).attr('id') == id) {
                    $(this).addClass('active in');
                    $('html,body').animate({
                        scrollTop: $(this).offset().top - 70
                    }, 500);
                }
                else {
                    $(this).removeClass('active in');
                }
            })
        }
