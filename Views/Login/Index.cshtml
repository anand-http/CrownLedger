        function PayLicenceNow() {
            var validatemsg = requiredFieldsForvalue($('#txtTotal'), "Total Amount cannot be 0")
                & requiredFields($('#txtNoofLicence'), "No of Licence cannot left blank", 1)
                & requiredFields($('#txtMonth'), "Month cannot left blank", 1)
            if (!validatemsg) {
                return false;
            }
            var Amount = 0;
            Amount = parseFloat($('#txtTotal').unmask());
            var nooflicence = parseFloat($('#txtNoofLicence').val());
            var month = parseFloat($('#txtMonth').val());
            if (isNaN(Amount)) {
                Amount = 0;
            }
            if (isNaN(nooflicence)) {
                nooflicence = 0;
            }
            if (isNaN(month)) {
                month = 0;
            }
            var AddRenew = "R";
            $('.btnlPayLicenceNow').hide();
            $('.btnlPayLicenceNow-loader').css('display', 'inline-block');
            $.ajax({
                url: "../Login/GetPaymentGatewayLicenceWithouLogin",
                type: "POST",
                dataType: "json",
                data: { Amount: Math.ceil(Amount), Advance: false, Requestto: 'PaymentBookLicence', LicenceType: $('#ddltype').val(), nooflicence: nooflicence, month: month, AddRenew: AddRenew, Currency: $('#hdnnewcurr').val(), EntityCode: $('#txtEntityCode').val(), EntityId: $('#hdnEntityID').val() },
                beforeSend: function () {
                    $('.saveloaderwrap').removeClass('invisible');
                },
                error: function (response, m2, m3) {
                    $('.saveloaderwrap').addClass('invisible');
                    $('.btnlPayLicenceNow').css('display', 'inline-block');
                    $('.btnlPayLicenceNow-loader').hide();
                    swal({ title: '<h2>Error occurred</h2>', text: '<p>' + response + '</p>', type: 'error', html: true, animation: true, });
                },
                failure: function (response) {
                    $('.saveloaderwrap').addClass('invisible');
                    $('.btnlPayLicenceNow').css('display', 'inline-block');
                    $('.btnlPayLicenceNow-loader').hide();
                    swal({ title: '<h2>Error occurred</h2>', text: '<p>' + response + '</p>', type: 'error', html: true, animation: true, });
                },
                success: function (response) {
                    $('.btnlPayLicenceNow').css('display', 'inline-block');
                    $('.btnlPayLicenceNow-loader').hide();
                    var ResrvRef = "LICENCE";
                    if (response.statusCode == "S0001" && response.CreditAllowed == false) {
                        var localurl = window.location.origin;
                        var left = (screen.width - 500) / 2;
                        var top = (screen.height - 500) / 4;
                        if (response.PaymentGatewayName == "Stripe") {
                            var newreceivedURL = "../Login/PaymentInitiateWithoutLogin?ClientName=" + $('#txtClient').val() + "&LOCALURL=" + localurl + "&ReserRef=" + ResrvRef + "";
                            newwindow = window.open(newreceivedURL, 'name', 'height=500,width=500, top=' + top + ', left=' + left);
                            if (window.focus) { newwindow.focus() }
                        }
                        else if (response.PaymentGatewayName.toUpperCase() == "CCAVENUE") {
                            var newreceivedURL = "../Login/PaymentInitiateWithoutLogin?ClientName=" + $('#txtClient').val() + "&LOCALURL=" + localurl + "&ReserRef=" + ResrvRef + "";
                            newwindow = window.open(newreceivedURL, 'name', 'height=500,width=500, top=' + top + ', left=' + left);
                            if (window.focus) { newwindow.focus() }
                            return false;
                        }
                        else {

                            var newreceivedURL = "../Login/PaymentInitiateWithoutLogin?ClientName=" + $('#txtClient').val() + "&LOCALURL=" + localurl + "&ReserRef=" + ResrvRef + "";
                            $("#modalCommon-body").html('<iframe width="100%" height="100%" frameborder="0" scrolling="yes" allowtransparency="true"  src="' + newreceivedURL + '"></iframe>');
                            $("#modalCommon").modal('show');
                            $("#modalCommon-body").height('580px');
                        }
                    }
                    else {
                        swal({ title: '<h2>Error occurred</h2>', text: '<p>' + response.statusMessage + '</p>', type: 'error', html: true, animation: true, });
                    }
                    $('.btnlPayLicenceNow').css('display', 'inline-block');
                    $('.btnlPayLicenceNow-loader').hide();
                }
            });
        }
        function CalculateAmount() {
            var PerLicencePrice = parseFloat($('#txtPerLicencePrice').unmask());
            var nofline = parseFloat($('#txtNoofLicence').val());
            var month = parseFloat($('#txtMonth').val());
            if (isNaN(PerLicencePrice)) {
                PerLicencePrice = 0;
            }
            if (isNaN(nofline)) {
                nofline = 0;
            }
            if (isNaN(month)) {
                month = 0;
            }
            var Grandtotal = (PerLicencePrice * nofline * month)
            $('#txtTotal').val(Grandtotal);
            $('.Price').priceFormat({ decPlace: 2, maxAllow: 14, minusAllow: true })
        }

        function Keyupfunctionchangebox(val1, val2,val3) {
            var code = event.keyCode || event.which;
            if (code == 8) {
                if (val3 != '') {
                    $('#' + val1).val('');
                    $('#' + val3).focus();
                }
                else {
                    $('#' + val1).val('');
                    $('#' + val1).focus();
                }
            }
            else if (code == 46)
            {
                $('#' + val1).val('');
                $('#' + val1).focus();
            }
            else {
                if (val2 != '') {
                    if ($('#' + val1).val().length) {
                        $('#' + val2).focus();
                    }
                }
            }
        }
