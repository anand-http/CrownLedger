                <div class="modal-body " style="background:#fff;">
                    <div class="row g-3">
                        @Html.HiddenFor(m => m.GL_ID)
                        @Html.HiddenFor(m => m.GL_CODE)
                        @Html.HiddenFor(m => m.Active)
                        @Html.HiddenFor(m => m.Curncy_ID)
                        <input type="hidden" id="GL_BRANCHID" name="GL_BRANCHID" value="@Model.GL_BRANCHID" />
                        <input type="hidden" id="GL_DeptmtID" name="GL_DeptmtID" value="@Model.GL_DeptmtID" />
                        <div class="col-md-3">
                            <div class="form-floating" id="the-basics-agents">
                                @Html.TextBox("GL_CODE", null, new { @class = "form-control", placeholder = "Enter Name", id = "glcode-input" })
                                <label for="GLCode">GL Code*</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating">
                                @Html.TextBox("GL_DESC", null, new { @class = "form-control", placeholder = "Enter Name", id = "description-input" })
                                <label for="Description">Description*</label>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="dash-form-group">
                                <label class="form-check-label d-block mb-2" for="Classification">Classification</label>
                                <div class="form-check form-check-inline">
                                    @Html.RadioButtonFor(m => m.GL_CLASS, "R", new { @class = "form-check-input", id = "GL_CLASS1" })
                                    <label class="form-check-label" for="GL_CLASS1">Revenue</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    @Html.RadioButtonFor(m => m.GL_CLASS, "E", new { @class = "form-check-input", id = "GL_CLASS2" })
