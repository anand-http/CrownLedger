                                    </span>
                                    <div class="form-switch">
                                        @Html.CheckBox("ActiveAccount", true, new { @class = "form-check-input", id = "activeaccount-checkbox" })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
