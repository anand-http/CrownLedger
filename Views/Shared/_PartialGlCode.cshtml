@model fintech.GetAllChartOfAccounts_Result

<div class="modal fade" id="glcodemodal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Business Expenses_10000</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            @using (Html.BeginForm("SaveGLCode", "Home", FormMethod.Post, new { @class = "glcode-form" }))
