            <div class="form-floating">
                @Html.DropDownList("TaxCode", new SelectList(new[] { "Select Tax Code", "Select Tax Code 2" }), new { @class = "form-select", id = "taxcode-select", @aria_label = "Floating label select example" })
                <label for="TaxCode">Set Default Tax Code</label>
            </div>
        </div>*@
                        <div class="col-md-2">
