                                </div>
                                <div class="form-check form-check-inline">
                                    @Html.RadioButtonFor(m => m.GL_CLASS, "A", new { @class = "form-check-input", id = "GL_CLASS3" })
                                    <label class="form-check-label" for="GL_CLASS3">Asset</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    @Html.RadioButtonFor(m => m.GL_CLASS, "L", new { @class = "form-check-input", id = "GL_CLASS4" })
                                    <label class="form-check-label" for="GL_CLASS4">Liability</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating" id="the-basics-agents">
                                @Html.TextBox("Branch", null, new { @class = "form-select typeahead offline-agent", placeholder = "Unselected", id = "txtCOAbranch" })
                                <label for="Branch">Branch*</label>
                                <input type="hidden" id="hdnCOAbranch" value="@Model.GL_BRANCHID" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating" id="the-basics-agents">
                                @Html.TextBox("Department", null, new { @class = "form-select typeahead offline-agent", placeholder = "Unselected", id = "txtCOAdept" })
                                <label for="Department">Department*</label>
                                <input type="hidden" id="hdnCOADept" value="@Model.GL_DeptmtID" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating" id="the-basics-agents">
                                @Html.TextBox("Currency", null, new { @class = "form-select typeahead offline-agent", placeholder = "Unselected", id = "txtCOACurrency" })
                                <label for="Currency">Currency</label>
                                <input type="hidden" id="hdnCOACurrencyId" value="@Model.Curncy_ID" />
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="dash-form-group">
                                        <label class="form-check-label" for="icaccount">IC Account</label>
                                        <div class="display-label yes">
                                            <span class="dash-check-group">
                                                <span class="yes">Yes</span>
                                                <span class="no">No</span>
                                            </span>
                                            <div class="form-switch">
                                                @Html.CheckBox("GL_IC", true, new { @class = "form-check-input", id = "icaccount-checkbox" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="dash-form-group">
                                        <label class="form-check-label" for="controlaccount">Control Account</label>
                                        <div class="display-label yes">
                                            <span class="dash-check-group">
                                                <span class="yes">Yes</span>
                                                <span class="no">No</span>
                                            </span>
                                            <div class="form-switch">
                                                @Html.CheckBox("GL_Control", true, new { @class = "form-check-input", id = "controlaccount-checkbox" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="dash-form-group">
                                        <label class="form-check-label" for="bankaccount">Bank Account</label>
                                        <div class="display-label yes">
                                            <span class="dash-check-group">
                                                <span class="yes">Yes</span>
                                                <span class="no">No</span>
                                            </span>
                                            <div class="form-switch">
                                                @Html.CheckBox("GL_Bank", true, new { @class = "form-check-input", id = "bankaccount-checkbox" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

