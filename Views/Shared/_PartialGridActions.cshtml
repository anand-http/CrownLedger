<!-- Modal -->

<div class="modal fade" id="emailpopup" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Email Sales Estimates</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body " style="background:#fff;">
                <div class="row g-3">
                    <div class="col-md-12">
                        <div class="form-floating" id="the-basics-agents">
                            <input class="form-control" id="txtEmailTo" type="text" placeholder="Enter Name">
                            <label for="floatingSelect">To*</label>
                        </div>
                    </div>
                    @*<div class="col-md-12">
                            <div class="form-floating" id="the-basics-agents">
                                <input class="form-control" type="text" placeholder="Enter Name">
                                <label for="floatingSelect">Cc*</label>
                            </div>
                        </div>*@
                    <div class="col-md-12">
                        <div class="form-floating" id="the-basics-agents">
                            <input class="form-control" type="text" id="txtSubject" placeholder="Enter Name">
                            <label for="floatingSelect">Subject*</label>
                        </div>
                    </div>
                    @*<div class="col-md-12">
                        <div class="form-floating upload">
                            <input class="form-control" type="text" placeholder="" value="Sales document">
                            <label for="floatingSelect">Attachment</label>
                            <input type="file" />
                        </div>
                    </div>*@
                    <div class="col-md-12">
                        <div class="form-floating">
                            <textarea class="form-control" id="txtMessage" style="height:124px;" value=""></textarea>
                            <label for="teamName">Message </label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" id="btnSendEmail" class="btn action-btn bg-action-light active">Send</button>
                <button type="button" class="btn action-btn bg-action-light" data-bs-dismiss="modal">Cancel</button>

            </div>
        </div>
    </div>
</div>


<div class="modal" id="importModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4>Import Customers</h4>
                @*<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>*@
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label>Select File</label>
                    <input type="file" id="fileUpload" class="form-control" accept=".csv,.xlsx" />
                    <small class="text-muted">Supported formats: CSV, XLSX</small>
                </div>

                <!-- Result alert shown after upload -->
                <div id="importAlert" class="alert" style="display:none;"></div>

                <div class="mt-3 Download_smp_container">
                    <p>Download Sample</p>
                    <div class="Download_smp_btn">
                        <a href="@Url.Action("DownloadSampleCSV", "Sales")" class="btn btn-success">
                            <i class="fa fa-download"></i>CSV
                        </a>
                        <a href="@Url.Action("DownloadSampleExcel", "Sales")" class="btn btn-success">
                            <i class="fa fa-file-excel-o"></i>Excel
                        </a>

                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-success" id="btnUpload">
                    <span id="btnUploadText">Upload File</span>
                    <span id="btnUploadSpinner" style="display:none;">
                        <i class="fa fa-spinner fa-spin"></i> Uploading...
                    </span>
                </button>
                <button class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>


<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content">

            <div class="modal-header">
                <h4 class="modal-title">
                    <i class="fa fa-download"></i> Export Customers
                </h4>
                @*<button type="button" class="close" data-dismiss="modal">&times;</button>*@
            </div>

            <div class="modal-body">

                <!-- Alert -->
                <div id="exportAlert" class="alert" style="display:none;"></div>

                <!-- Export Format -->
                <div class="form-group">
                    <label>Export Format</label>
                    <div>
                        <label class="radio-inline">
                            <input type="radio" name="exportFormat" value="Excel" checked />
                            <i class="fa fa-file-excel-o text-success"></i> Excel (.xlsx)
                        </label>
                        <label class="radio-inline" style="margin-left:20px;">
                            <input type="radio" name="exportFormat" value="CSV" />
                            <i class="fa fa-file-text-o text-primary"></i> CSV (.csv)
                        </label>
                    </div>
                </div>

                <hr />
                <div id="exportSummary" class="alert alert-info" style="font-size:13px; display:none;">
                    <i class="fa fa-info-circle"></i>
                    <span id="exportSummaryText"></span>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-success" id="btnExport">
                    <span id="btnExportText">
                        <i class="fa fa-download"></i> Export
                    </span>
                    <span id="btnExportSpinner" style="display:none;">
                        <i class="fa fa-spinner fa-spin"></i> Exporting...
                    </span>
                </button>
                <button class="btn btn-default" data-dismiss="modal">
                    Cancel
                </button>
            </div>

        </div>
    </div>
</div>
