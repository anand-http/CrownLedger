    @RenderSection("scripts", required: false)

    <script>

        function getSuffix(element) {
            var classes = $(element).closest("tr").attr("class").split(" ");
            var rowClass = classes.find(function (c) { return c.startsWith("row-"); });
            return rowClass ? rowClass.split("-")[1] : null;
        }
        $(document).ready(function () {
            var path = window.location.pathname.toLowerCase();

            $(".nav-bar .nav-item").removeClass("active");

            if (path.includes("/sales")) {
                $("a[href*='Sales']").closest(".nav-item").find(".nav-link").addClass("active");
            }
            else if (path.includes("/purchase")) {
                $("a[href*='Purchase']").closest(".nav-item").find(".nav-link").addClass("active");
            }
            else if (path.includes("/adjustment")) {
                $("a[href*='Adjustment']").closest(".nav-item").find(".nav-link").addClass("active");
            }
            else if (path.includes("/reports")) {
                $("a[href*='Reports']").closest(".nav-item").find(".nav-link").addClass("active");
            }
            else if (path.includes("/configuration")) {
                $("a[href*='Configuration']").closest(".nav-item").find(".nav-link").addClass("active");
            }
            else if (path.includes("/banking")) {
                $("a[href*='Banking']").closest(".nav-item").find(".nav-link").addClass("active");
            }
            else {
                $("a[href*='Dashboard']").closest(".nav-item").find(".nav-link").addClass("active");
            }

        });
    </script>

