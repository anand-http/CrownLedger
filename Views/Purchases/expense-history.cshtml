        $(document).ready(function () {

            // Function to toggle GST fields for a specific tab
            function toggleGSTFields(tabSelector) {
                let gstCheckbox = $(tabSelector).find('.gst-toggle');
                let taxCodeField = $(tabSelector).find('.gst-tax-code');
                let taxAmountField = $(tabSelector).find('.gst-tax-amount');

                function updateGSTState() {
                    let isChecked = gstCheckbox.is(':checked');
                    if (!isChecked) {
                        taxCodeField.prop('disabled', true);
                        taxAmountField.prop('disabled', true);
                        taxCodeField.val('');
                        taxCodeField.siblings('input[type="hidden"]').val('');
                        taxAmountField.val('');
                    } else {
                        taxCodeField.prop('disabled', false);
                        taxAmountField.prop('disabled', false);
                    }
                }

                updateGSTState();
                gstCheckbox.on('change', updateGSTState);
            }

            // Function to toggle TDS fields for a specific tab
            function toggleTDSFields(tabSelector) {
                let tdsCheckbox = $(tabSelector).find('.tds-toggle');
                let tdsCodeField = $(tabSelector).find('.tds-code');
                let tdsAmountField = $(tabSelector).find('.tds-amount');

                function updateTDSState() {
                    let isChecked = tdsCheckbox.is(':checked');
                    if (!isChecked) {
                        tdsCodeField.prop('disabled', true);
                        tdsAmountField.prop('disabled', true);
                        tdsCodeField.val('');
                        tdsCodeField.siblings('input[type="hidden"]').val('');
                        tdsAmountField.val('');
                    } else {
                        tdsCodeField.prop('disabled', false);
                        tdsAmountField.prop('disabled', false);
                    }
                }

                updateTDSState();
                tdsCheckbox.on('change', updateTDSState);
            }

            // Initialize toggles for Expense tab (pills-address)
            toggleGSTFields('#pills-address');
            toggleTDSFields('#pills-address');

            // Initialize toggles for Recurring Expense tab (pills-contacts)
            toggleGSTFields('#pills-contacts');
            toggleTDSFields('#pills-contacts');


        });


