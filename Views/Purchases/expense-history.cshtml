<script>



        var ExpenseHistory;
        var selectedStatus = "";
        var startDate;
        var endDate;

        $(document).ready(function () {
            ExpenseHistory = $("#expenseHistory").DataTable({
           "serverSide": true,
           select: {
               style: 'multi'
           },
           buttons: [
               {
                   extend: 'copy',
                   text: 'Copy',
                   exportOptions: {
                       modifier: {
                           selected: true
                       }
                   }
               },
               {
                   extend: 'excel',
                   text: 'Excel',
                   exportOptions: {
                       modifier: {
                           selected: true
                       }
                   }
               },
               {
                   extend: 'csv',
                   text: 'CSV',
                   exportOptions: {
                       modifier: {
                           selected: true
                       }
                   }
               },
               {
                   extend: 'pdf',
                   text: 'PDF',
                   exportOptions: {
                       modifier: {
                           selected: true
                       }
                   }
               },
               {
                   extend: 'print',
                   text: 'Print',
                   exportOptions: {
                       modifier: {
                           selected: true
                       },

                   }
               }
           ],
           "ajax": {
               "url": "@Url.Action("GetExpenseHistory")",
               "type": "POST",
               "datatype": "json",
               "data": function (d) {
                   d.icolelngth = 8;
                   d.statusFilter = selectedStatus;
                   d.startDate = startDate;
                   d.endDate = endDate;
               },
               "beforeSend": function () {

               },
               "complete": function () {
               }
           },
           createdRow: function (row, data, dataIndex) {
               $(row).attr('data-id', data.ExpenseId);
           },
           "columns": [
               {
                   "data": "ExpenseDate",
                   "name": "ExpenseDate",
                   "autoWidth": true,
                   "visible": true,
                   "class": "d-flex align-items-center",
                   "render": function (data, type, row, meta) {
                       return `
                <div class="d-flex align-items-center">
                  <div class="inputlabel d-flex align-items-center me-2">
                      <input class="form-check-input mt-0 row-check" type="checkbox" value="" id="expenseDate_${meta.row}">
                  </div>
                  ${data ? moment(data).format("DD-MM-YYYY") : ""}
               </div>`;
                   }
               },
               { "data": "VendorName", "name": "VendorName", "autoWidth": true, "visible": true, "class": "center" },
               { "data": "LedgerAccount", "name": "LedgerAccount", "autoWidth": true, "visible": true, "class": "center" },
               { "data": "ExpenseAmount", "name": "ExpenseAmount", "autoWidth": true, "visible": true, "class": "center" },
               { "data": "PaidFrom", "name": "PaidFrom", "autoWidth": true, "visible": true, "class": "center" },
               { "data": "Status", "name": "Status", "autoWidth": true, "visible": true, "class": "center" },
               { "data": "CreatedBy", "name": "CreatedBy", "autoWidth": true, "visible": true, "class": "center" },
               {
                   "data": "CreatedOn", "name": "CreatedOn", "autoWidth": true, "visible": true, "class": "center",
                   render: function (data) {
                       return data ? moment(data).format("DD-MM-YYYY") : "";
                   }
               },
           ],
           "fnInitComplete": function (oSettings) {
               var j = 0;
           }
          });

        });


       //Sync the row checkbox with datatable
      $('#expenseHistory').on('change', '.row-check', function () {
           var row = $(this).closest('tr');

           if (this.checked) {
               ExpenseHistory.row(row).select();
           } else {
               ExpenseHistory.row(row).deselect();
           }
       });


       //Toggle the column
       let resetClicked = false;

       $('#resetColumns').click(function () {
