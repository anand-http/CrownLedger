function SaveRecordingExpense() {
    var activeTab = $('.tab-pane.show.active');
    var tabId = activeTab.attr('id');

    // Validate required fields
    //if (!ValidateExpenseForm(activeTab, tabId)) {
    //    return false;
    //}

    var expenseData = {};

    if (tabId === 'pills-address') {
        // Main Expense Tab

        let expenseDate = activeTab.find('#expenseDate').val();
        let formatedExpenseDate = expenseDate ? new Date(expenseDate).toISOString() : "";
        expenseData = {
            RecordType:"Expense",
            ExpenseType: $('input[name="inlineRadioOptions"]:checked').val() === "option1" ? "Goods" : "Service",
            HsnCode: activeTab.find('#hsnCode').val(),
            BranchId: activeTab.find('#hdnBranchId').val(),
            DepartmentId: activeTab.find('#hdnDepartmentId').val(),
            ExpenseLedgerId: activeTab.find('#hdnExpenseLedgerId').val(),
            ExpenseDate: formatedExpenseDate,
            Description: activeTab.find('#description').val(),
            ExpenseAmount: activeTab.find('#expenseAmount').val(),
            VendorId: activeTab.find('#hdnVendorId').val(),
            PaidFrom: activeTab.find('#expensePaidFrom').val(),
            GstApplicable: activeTab.find('#icaccount').eq(0).is(':checked'),
            GstTaxCode: activeTab.find('#hdnTaxCode').val(),
            TaxAmount: activeTab.find('#taxAmount').val(),
            ItcAvailable: activeTab.find('#itcAvailablityExpense').val(),
            TdsChargeable: activeTab.find('#icaccount').eq(1).is(':checked'),
            TdsCode: activeTab.find('#hdnTdsCode').val(),
            TdsAmount: activeTab.find('#tdsAmount').val(),
            SaveAsDraft: activeTab.find('#billing-address').is(':checked')
        };
    }
    else if (tabId === 'pills-contacts') {
        // Recurring Expense Tab
        let starDate = activeTab.find('#recStartDate').val();
        let endDate = activeTab.find('#recEndDate').val();

        let formatedStarDate = starDate ? new Date(starDate).toISOString() : "";
        let formatedEndDate = endDate ? new Date(endDate).toISOString() : "";
        expenseData = {
            RecordType: "RecurringExpense",
            ExpenseType: $('input[name="inlineRadioOptions"]:checked').val() === "option1" ? "Goods" : "Service",
            HsnCode: activeTab.find('#recHsnCode').val(),
            BranchId: activeTab.find('#hdnRecBranchId').val(),
            DepartmentId: activeTab.find('#hdnRecDepartmentId').val(),
            ExpenseLedgerId: activeTab.find('#hdnRecExpenseLedgerId').val(),
            ExpenseAmount: activeTab.find('#recExpenseAmount').val(),
            Description: activeTab.find('#recDescription').val(),
            Frequency: activeTab.find('#frequency').val(),
            StartDate: formatedStarDate,
            EndDate: formatedEndDate,
            PaidFrom: activeTab.find('#recExpensePaidFrom').val(),
            VendorId: activeTab.find('#hdnRecVendorId').val(),
            GstApplicable: activeTab.find('#icaccount').eq(0).is(':checked'),
            GstTaxCode: activeTab.find('#hdnRecTaxCode').val(),
            TaxAmount: activeTab.find('#recTaxAmount').val(),
            ItcAvailable: activeTab.find('#itcAvailablityRec').val(),
            TdsChargeable: activeTab.find('#icaccount').eq(1).is(':checked'),
            TdsCode: activeTab.find('#hdnRecTDS').val(),
            TdsAmount: activeTab.find('#recTDSAmount').val(),
            SaveAsDraft: activeTab.find('#billing-address').is(':checked')
        };
    }
    else if (tabId === 'pills-other') {
        // Bulk Booking Tab
        var bulkItems = [];
        var tableRows = activeTab.find('table tbody tr');
        tableRows.each(function (index) {
            var row = $(this);
            let suffix = index + 1;
            let bulkbookDate = row.find(`#bulkBookingDate_${suffix}`).val();
            let formatedBulkbookDate = bulkbookDate ? new Date(bulkbookDate).toISOString() : "";
            var rowData = {
                Date: formatedBulkbookDate,
                ExpenseLedgerId: row.find('#hdnExpenseLedger_' + suffix).val(),
                Description: row.find('#bulkDescription_' + suffix).val(),
                Amount: row.find('#amountValue_' + suffix).val(),
                AmountCurrency: row.find('#amountCurrency_' + suffix).val(),
                TaxAmount: row.find('#taxValue_' + suffix).val(),
                TaxCurrency: row.find('#taxCurrency_' + suffix).val(),
                VendorId: row.find('#hdnVendorId_' + suffix).val(),
                PaidFrom: row.find('.bulkPaidFromInput').val(),
                BranchId: row.find('#hdnBranchId_' + suffix).val(),
                DepartmentId: row.find('#hdnDepartment_' + suffix).val()
            };
            bulkItems.push(rowData);
        });

        expenseData = {
            bulkBookingItems: bulkItems,
            RecordType:"BulkBooking",
            saveAsDraft: activeTab.find('#billing-address').is(':checked')
        };
    }

    $.ajax({
        url: "@Url.Action("SaveExpense", "Purchases")",
        type: "POST",
        contentType: "application/json",
        data: JSON.stringify(expenseData),
        dataType: "json",
        success: function (response) {
            if (response.Success) {
                var modalEl = document.getElementById('recording-of-expense');
                var modal = bootstrap.Modal.getInstance(modalEl);
                modal.hide();
                ClearExpenseForm();
                Swal.fire({
                    icon: 'success',
                    title: 'Success',
                    text: 'Expense saved successfully',
                    timer: 5000,
                    confirmButtonColor: '#3085d6'
                })
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Error occured while saving Expense!',
                    timer: 5000,
                    confirmButtonColor: '#d33'
                })
            }
        },
        error: function (xhr, status, error) {
            console.error("Error:", error);
            alert("error occured");
            var errorMsg = "An error occurred while saving the expense.";
            if (xhr.responseJSON && xhr.responseJSON.message) {
                errorMsg = xhr.responseJSON.message;
            }
        }
    });
}

function ValidateExpenseForm(tabElement, tabId) {
    var isValid = true;
    var errorMessages = [];

    if (tabId === 'pills-address' || tabId === 'pills-contacts') {
        // Validate Expense Type
        var expenseType = $('input[name="inlineRadioOptions"]:checked').val();
        if (!expenseType) {
            errorMessages.push("Please select an expense type (Goods or Service)");
            isValid = false;
        }

        // Validate Vendor Name
        var vendorName = tabElement.find('#txtVendorName').val();
        if (!vendorName || vendorName.trim() === '') {
            errorMessages.push("Vendor Name is required");
            isValid = false;
        }

        // Validate Expense Amount
        var expenseAmount = tabId === 'pills-address'
            ? tabElement.find('input.form-control').eq(5).val()
            : tabElement.find('input.form-control').eq(3).val();
        if (!expenseAmount || isNaN(expenseAmount) || parseFloat(expenseAmount) <= 0) {
            errorMessages.push("Please enter a valid Expense Amount");
            isValid = false;
        }

        // Validate Date
        var dateField = tabId === 'pills-address'
            ? tabElement.find('input[name="fiscaldate"]').val()
            : tabElement.find('input[name="fiscaldate"]').eq(0).val();
        if (!dateField) {
            errorMessages.push("Date is required");
            isValid = false;
        }

        // Validate Branch/Department/Ledger
        if (tabId === 'pills-address') {
            var branch = tabElement.find('#txtBranch').val();
            if (!branch || branch.trim() === '') {
                errorMessages.push("Branch is required");
                isValid = false;
            }
        }
    }
    else if (tabId === 'pills-other') {
        // Validate Bulk Booking
        var tableRows = tabElement.find('table tbody tr');
        if (tableRows.length === 0) {
            errorMessages.push("Please add at least one item for Bulk Booking");
            isValid = false;
        } else {
            var hasValidRow = false;
            tableRows.each(function (index) {
                var row = $(this);
                var amount = row.find('input.text-end').eq(0).val();
                var date = row.find('input[name="fiscaldate"]').val();

                if (amount && date && !isNaN(amount) && parseFloat(amount) > 0) {
                    hasValidRow = true;
                }
            });

            if (!hasValidRow) {
                errorMessages.push("Please ensure all items have valid Date and Amount");
                isValid = false;
            }
        }
    }

    if (!isValid) {
        ShowNotification(errorMessages.join('<br>'), "error");
    }

    return isValid;
}


 (function () {
     function isActiveTabDirty() {
         var $active = $('.tab-pane.active');
         if (!$active.length) return false;

         // 1. Check visible inputs (text, textarea, select)
         var hasValue = $active.find('input[type="text"], textarea')
             .filter(function () {

                 // skip hidden elements
                 if ($(this).is(':hidden')) return false;

                 // skip fiscal date fields
                 if ($(this).attr('name') === 'fiscaldate') return false;

                 var v = $(this).val();
                 return v !== null && v.toString().trim() !== '';
             }).length > 0;

         // 2. Check hidden inputs (ONLY those used for dropdowns)
         var hasHiddenValue = $active.find('input.track-value')
             .filter(function () {
                 var v = $(this).val();
                 return v && v.toString().trim() !== '';
             }).length > 0;

         // 3. Check radio / checkbox (if needed)
         //var hasChecked = $active.find('input[type="radio"], input[type="checkbox"]')
         //    .filter(':checked').length > 0;
         var rowIncrease = rowCount>1
         return hasValue || hasHiddenValue || rowIncrease;
     }

    // Intercept pill tab clicks and show Swal if active tab is dirty
     $('#pills-tab').on('show.bs.tab', '.nav-link', function (e) {
        if (isActiveTabDirty()) {
            e.preventDefault();
            Swal.fire({
                icon: 'warning',
                title: 'Cannot switch tab',
                text: 'You have unsaved changes. Please save or discard them before switching tabs.',
                confirmButtonColor: '#3085d6'
            });
        }
    });
})();




function ClearExpenseForm() {

        // Remove any inline alerts
        $('#recording-of-expense .alert').remove();

        // Clear fields in each tab
        $('#recording-of-expense .tab-pane').each(function () {
            var $tab = $(this);

            // Clear visible inputs and textareas
            $tab.find('input[type="text"], input[type="email"], textarea').val('');

            // Reset selects to first option
            $tab.find('select').each(function () {
                $(this).prop('selectedIndex', 0);
            });

            // Clear hidden inputs (IDs etc.)
            $tab.find('input[type="hidden"]').val('');
            $tab.find('input[type="Search"]').val('');

            // Uncheck all checkboxes and radios, then set default radio for expense type
            $tab.find('input[type="checkbox"]').prop('checked', false);
            $tab.find('input[type="radio"]').prop('checked', false);
            $tab.find('input[name="inlineRadioOptions"]').first().prop('checked', true);

            // Destroy any daterangepicker instance and clear value
            $tab.find('input.datepicker, input[name="fiscaldate"]').each(function () {
                var $inp = $(this);
                var dr = $inp.data('daterangepicker');
                if (dr && typeof dr.remove === 'function') {
