                                            <label for="paymentTerms">Payment Terms</label>
                                        </div>
                                    </div>
                                    <div class="col">
                                        <div class="form-floating mb-3">
                                            <input type="text" class="form-control datepicker" id="expectedDeliveryDate" name="fiscaldate" placeholder="">
                                            <label for="ExpectedDeliveryDate">Expected Delivery Date</label>
                                        </div>
                                    </div>
                                    <div class="col">
                                        <div class="form-floating">
                                            <input class="form-select typeahead offline-agent"
                                                   type="text" placeholder="" id="txtBranch">
