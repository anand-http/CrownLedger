                                        <span>Upload</span><input type="file">
                                    </div>
                                    <a href="javascript:void(0);" class="action-btn bg-action-light active">Save as Draft</a>
                                    <a href="javascript:void(0);" class="action-btn bg-action-light">Mark as Issued</a>
                                    <div class="dropdown">
                                        <a class="form-select dropdown-toggle text-decoration-none" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <span class="">Save</span>
                                        </a>
                                        <ul class="dropdown-menu">
                                            <li><a class="dropdown-item" href="javascript:void(0)">Save and  Approve</a></li>
                                            <li><a class="dropdown-item" href="javascript:void(0)" onclick="CreateNewPurchaseOrder(this)" data-status="SS">Save and Submit</a></li>
                                        </ul>
                                    </div>
                                    <a href="javascript:void(0);" class="action-btn bg-action-light">Cancel</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Modal -->


    <script>
    //Typehead

    $('#txtVendorName').typeheadAutoComplete('Partner.mst_Partner', 'Partner', $('#hdnVendorId'));
    $('#txtBranch').typeheadAutoComplete('CORE.mst_Branch', 'Branch', $('#hdnBranchId'));
    $('#txtCurrency').typeheadAutoComplete('[Core].[mst_Currency]', 'Curncy', $('#hdnCurrencyId'));


     function CreateNewPurchaseOrder(el) {
     const vendorId = $('#hdnVendorId').val();
     if (!vendorId) {
         Swal.fire({
             icon: 'error',
             title: 'Oops..',
             text: 'Please select a vendor',
             timer: 5000,
             confirmButtonColor: '#d33'
         });
         return;
     }

         let orderDate = $('#purchaseOrderDate').val();
         let expDeliveryDate = $('#expectedDeliveryDate').val();

         // convert to yyyy-MM-dd
         var formattedOrderDate = orderDate ? new Date(orderDate).toISOString() : null;
         var formattedExpDate = expDeliveryDate ? new Date(expDeliveryDate).toISOString() : null;

         const headerData = {
         VendorId: parseInt(vendorId),
         ReferenceNumber: $('#reference').val(),
         PurchaseOrderDate: formattedOrderDate,
         DeliveryAddress: $('#deliveryAddress').val(),
         CurrencyId: $('#hdnCurrencyId').val(),
         Payment_Term1: 0,
         Payment_Term2: $('#paymentTerms').val(),
         ExpectedDeliveryDate: formattedExpDate,
         BranchId: $('#hdnBranchId').val(),
         SubTotal: $("#lblSubTotal").text().replace("$", "").trim(),
         Tax_Value: parseFloat($('#txtTaxValue').val()) || 0,
         TotalAmount: parseFloat($('#lblTotal').text().replace(/[^\d.-]/g, '')) || 0,
         Discount: $('#txtDiscount').val() || 0,
         OtherAdjustment: parseFloat($('#txtOtherAdjustment').val()) || 0,
         Status: $(el).data('status'),
         POStatus: "",
         BillingStatus: "",
         Comments: $('#txtComments').val(),
         TermsAndConditions: $('#txtTermsConditions').val(),
     };

         const items = getAllItemRowsFn();

     if (items.length === 0) {
         Swal.fire({
             icon: 'error',
             title: 'Oops...',
             text: 'Please add at least one item',
             confirmButtonColor: '#d33'
         });
         return;
     }

     for (let i = 0; i < items.length; i++) {
         if (!items[i].ItemId || parseFloat(items[i].ItemId) <= 0) {
             Swal.fire({
                 icon: 'error',
                 title: 'Oops...',
                 text: 'ItemId is required',
                 confirmButtonColor: '#d33'
             });
             return;
         }
     }
     const payload = {
         ...headerData,
         Items: items
     };

     $.ajax({
         type: 'POST',
         url: '@Url.Action("SavePurchaseOrder", "Purchases")',
         contentType: 'application/json',
         data: JSON.stringify(payload),
         success: function (response) {
             if (response.status) {
                 Swal.fire({
                     icon: 'success',
                     title: 'Success',
                     text: 'Purchase Order saved successfully',
                     timer: 5000,
                     confirmButtonColor: '#3085d6'
                 }).then((result) => {
                     window.location.href = '/Purchases/PurchaseOrderHistory';
                 });
             } else {
                 Swal.fire({
                     icon: 'error',
                     title: 'Error',
                     text: response.message || 'Failed to save',
                     confirmButtonColor: '#d33'
                 });
             }
         },
         error: function (error) {
             console.error('Error:', error);
             Swal.fire({
                 icon: 'error',
                 title: 'Oops...',
                 text: 'An error occurred while saving the Purchase Order',
                 confirmButtonColor: '#d33'
             });
         }
     });
 }

    </script>


