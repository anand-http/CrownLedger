             $('#txtvPCountry').val(customer.Country || '');
             $('#hdnvPCountryID').val(customer.Contry_Id || '');
             $('#txtvZip').val(customer.ZipCode || '');

             // ── Correspondence Address
             $('#txtvCAddress1').val(customer.CAddress1 || '');
             $('#txtvCAddress2').val(customer.CAddress2 || '');
             $('#txtvCCity').val(customer.CCity || '');
             $('#txtvCState').val(customer.State || '');
             $('#txtvCCountry').val(customer.Country || '');
             $('#txtvCZip').val(customer.ZipCode2 || '');

             // ── Other Details — Tax
             $('#txtVGST').val(customer.GST_VAT || '');
             $('#txtVPAN').val(customer.PAN || '');
             $('#txtVTaxCode').val(customer.TaxCode || '');

             // ── Bank Details (single row in view)
             $('#txtvCurrencyBD').val(customer.BankCurrency || '');
             $('#hdnvCurrencyBD').val(customer.Currency_Id || '');
             $('#txtvAccountNumber').val(customer.AccountNumber || '');
             $('#txtvPayee').val(customer.Payee || '');
             $('#txtvBankName').val(customer.BankName || '');
             $('#txtvIFSC').val(customer.IBAN_IFSC || '');
             $('#txtvSWIFT').val(customer.SWIFTCode || '');
             $('#txtvSORT').val(customer.SORTCode || '');
             $('#txtvDefaultBank').prop('checked', customer.IsDefaultBank === true);

             // ── Contacts — rebuild rows
             var partnerId = Number(customer.Partner_Id);
             var $contactBody = $('#contactTableBody');
             $contactBody.empty();

             var contactRows = (vendorData && vendorData.contacts || []).filter(function (c) {
                 return Number(c.Contact_SourceID) === partnerId;
             });

             if (contactRows.length > 0) {
                 contactRows.forEach(function (contact, index) {
                     $contactBody.append(buildContactRow(index, contact));
                     $('#txtvDepart_' + index).typeheadAutoComplete('Core.mst_ContactType', 'Contyp', $('#hdnvDepartID_' + index));
                 });
             } else {
                 $contactBody.append(buildContactRow(0, null));
                 $('#txtvDepart_1').typeheadAutoComplete('Core.mst_ContactType', 'Contyp', $('#hdnvDepartID_1'));
             }

             // ── Payment Terms — rebuild rows
             var $paymentBody = $('#paymentTermsBody');
             $paymentBody.empty();

             var paymentRows = (vendorData && vendorData.paymentterms || []).filter(function (p) {
                 return Number(p.Partner_Id) === partnerId;
             });

             if (paymentRows.length > 0) {
                 paymentRows.forEach(function (term, index) {
                     var rowIndex = index + 1;
                     $paymentBody.append(buildPaymentTermRow(rowIndex, term));
                     $('#txtvTerm_' + rowIndex).typeheadAutoComplete('COMMON.mst_Terms', 'Term', $('#hdnvTermId_' + rowIndex));
                 });
             } else {
                 $paymentBody.append(buildPaymentTermRow(1, null));
                 $('#txtvTerm_1').typeheadAutoComplete('COMMON.mst_Terms', 'Term', $('#hdnvTermId_1'));
             }

             $('#exampleModalLabel').text('Update Vendor');
         }

         if (rowData && typeof rowData.Partner_Id !== 'undefined') {
             populateCustomer(rowData);
             return;
         }
     }
 });

