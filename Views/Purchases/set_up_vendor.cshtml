    $(document).ready(function () {
    // Duplicate row
        $('#CreateVendormodal').on('click', '.icon.cursor-pointer', function () {
            var $row = $(this).closest('tr');
            var $tbody = $row.closest('tbody');
            var rowCount = $tbody.find('tr').length;
            var maxRows = 10;

            if (rowCount < maxRows) {
                var newIndex = rowCount; // 0-based: existing rows are 0,1,2... so next is rowCount
                $tbody.append(buildContactRow(newIndex, null));
                $('#txtvDepart_' + newIndex).typeheadAutoComplete('Core.mst_ContactType', 'Contyp', $('#hdnvDepartID_' + newIndex));
            } else {
                alert('Maximum 10 contact rows allowed.');
            }
        });

    // Delete row
    $('#CreateVendormodal').on('click', '.minus-icon', function () {
        var $tbody = $(this).closest('tbody');
        // Don't delete if only 1 row remains
        if ($tbody.find('tr').length > 1) {
            $(this).closest('tr').remove();
        }
    });

        $('#CreateVendormodal').on('click', '.add-another-payment-terms', function () {

        var $row = $(this).prev('.payment-terms');
            var rowCount = $('#CreateVendormodal .payment-terms').length;
        var maxRows = 5;

        if (rowCount < maxRows) {

            var $clone = $row.clone();
            // Clear all inputs
            $clone.find('input').val('');
            // Reset dropdowns
            $clone.find('select').prop('selectedIndex', 0);
            // Reset toggle
            $clone.find('.default-payment-term').prop('checked', false);
            // Insert new payment term after current one
            $clone.insertAfter($row);
            // Update numbering
            updatePaymentTermNumbers();

        } else {
            alert('Maximum 5 payment terms allowed.');
        }

    });
    $('#CreateVendormodal').on('click', '#deleteterm', function () {

        var totalTerms = $('#CreateVendormodal .payment-terms').length;
        if (totalTerms > 1) {
            $(this).closest('.payment-terms').remove();
            updatePaymentTermNumbers();
        } else {
            alert('At least one payment term is required.');
        }
    });

    function updatePaymentTermNumbers() {
        $('#CreateVendormodal .payment-terms').each(function (index) {
            $(this).find('.header-title')
                .text('Payment Term ' + (index + 1));
        });

    }

    // Ensure at least one default payment term
    $('#CreateVendormodal').on('change', '#icaccount', function () {
        var $tbody = $(this).closest('tbody');
        var checkedCount = $tbody.find('.default-payment-term:checked').length;
        if (checkedCount === 0) {
            alert('At least one payment term must be set as default.');
            $(this).prop('checked', true);
        }
    });

});

    function saveVendor() {
            var contactDetails = [];
            $('#contactdetails tbody tr').each(function (index) {
                var $row = $(this);
                var name = $('#txtClientName_' + index).val();
                var department = $('#txtvDepart_' + index).val();
                var designation = $('#txtDesignation_' + index).val();
                var phone = $('#txtTelephone_' + index).val();
                var email = $('#txtEmail_' + index).val();
                var mobile = $('#txtMobile_' + index).val();
                var fax = $('#txtFax_' + index).val();

                if (name || department || designation || phone || email || mobile || fax) {
                    contactDetails.push({
                        Contact_Name: name,
                        Contact_Type: department,
                        Designation: designation,
                        Contact_Phone: phone,
                        Contact_Email: email,
                        Mobile: mobile,
                        Contact_Fax: fax
                    });
                }
            });
            var paymentterms = [];
            $('#paymentTermsBody  tr').each(function (index) {  // <-- capture index here
                var $row = $(this);
                var rowIndex = index + 1;
                var billPerc = $('#txtBillPerc_' + rowIndex).val();
                var dueDateBasedOn = $('#txtTerm_' + rowIndex).val();
                var dueDateId = $('#hdnvTermId_' + rowIndex).val();
                var creditDays = $('#txtCreditDays_' + rowIndex).val();
                var creditLimits = $('#txtCreditLimits_' + rowIndex).val();
                var isDefault = $('#icaccount_' + rowIndex).is(':checked');

                if (billPerc || dueDateBasedOn || dueDateId || creditDays || creditLimits || isDefault) {
                    paymentterms.push({
                        BillPercentage: billPerc,
                        DueDateBasedOn: dueDateId,
                        termsId: dueDateId,
                        CreditDays: creditDays,
                        CreditLimits: creditLimits,
                        IsDefaultBank: isDefault,
                    });
                }
            });
            var status = "";
            if ($('#Client_Status').val() == "Deactivated") {
                status = "D";
            } else if ($('#Client_Status').val() == "Approved") {
                status = "A";
            } else if ($('#Client_Status').val() == "On Hold") {
                status = "H";
            } else {
                status = "A";
            }
        var model = {
            Contacts: contactDetails,
            PaymentTerms: paymentterms,

            // Hidden fields
            Partner_Id: $('#Client_ID').val(),
            Entity_ID: $('#hdnEntityId').val(),
            Partner_Status: $('#Client_Status').val(),
            AmountOutstanding: $('#hdnAmtOutstng').val(),
            UnusedCredit: $('#hdnUnusedCredit').val(),

            // General Details
            Name: $('#txtvBusinessName').val(),
            Partner_Code: $('#txtvCode').val(),
            Email: $('#txtvEmail').val(),
            Telephone: $('#txtvTelephone').val(),
            Website: $('#txtvWebsite').val(),

            // General — typeahead hidden IDs
            Country: $('#hdnvCountryID').val(),
            State: $('#hdnvStateID').val(),
            Department: $('#hdnDepartID').val(),
            DefaultCurrency: $('#hdnvCurrencyID').val(),

            // Physical Address
            Address1: $('#txtvAddress1').val(),
            Address2: $('#txtvAddress2').val(),
            ZipCode: $('#txtvZip').val(),
            City: $('#hdnvCityID').val(),          // Physical city hidden
            PState: $('#hdnvPStateID').val(),      // Physical state hidden
            PCountry: $('#hdnvPCountryID').val(),  // Physical country hidden

            // Correspondence Address
            CorrespondenceAddress1: $('#txtvCAddress1').val(),
            CorrespondenceAddress2: $('#txtvCAddress2').val(),
            City2: $('#txtvCCity').val(),
            State2: $('#txtvCState').val(),
            Country2: $('#txtvCCountry').val(),
            ZipCode2: $('#txtvCZip').val(),

            // Other Details — Tax
            GST_VAT: $('#txtVGST').val(),
            PAN: $('#txtVPAN').val(),
            TaxCode: $('#hdnvTaxID').val(),

            // Bank Details
            BankCurrency: $('#hdnvCurrencyBD').val(),
            AccountNumber: $('#txtvAccountNumber').val(),
            Payee: $('#txtvPayee').val(),
            BankName: $('#txtvBankName').val(),
            IBAN_IFSC: $('#txtvIFSC').val(),
            SWIFTCode: $('#txtvSWIFT').val(),
            SORTCode: $('#txtvSORT').val(),
            IsDefaultBank: $('#txtvDefaultBank').is(':checked'),
        };
    //comment
    $.ajax({
        url: '@Url.Action("CreateVendor", "Purchases")',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(model),
        success: function (response) {
            if (response.success) {
                alert('Customer saved successfully!');
                // Optionally reload or update UI
                $('#CreateVendormodal').modal('hide');
                location.reload();
            } else {
                alert(response.message || 'An error occurred while saving the vendor.');
            }
        },
        error: function (xhr) {
            console.log('Status:', xhr.status);
            console.log('Response:', xhr.responseText);
            alert('Error ' + xhr.status + ': ' + xhr.responseText);
            alert('An error occurred while saving the vendor.');
        }
    });
}

