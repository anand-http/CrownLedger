        $("#btnExport").click(function () {
            var exportType      = $("input[name='exportFormat']:checked").val();

            $("#btnExportText").hide();
            $("#btnExportSpinner").show();
            $("#btnExport").prop("disabled", true);
            $("#exportAlert").hide();

            $.ajax({
                url:  "@Url.Action("ExportCustomers", "Sales")",
                type: "POST",
                data: {
                    exportType:exportType
                },
                xhrFields: { responseType: "blob" },
                success: function (blob, status, xhr) {
                    var extension = exportType === "CSV" ? "csv" : "xlsx";
                    var filename  = "Customers_Export_" + getTimestamp() + "." + extension;

                    // read filename from header if server provides it
                    var disposition = xhr.getResponseHeader("Content-Disposition");
                    if (disposition) {
                        var match = disposition.match(/filename="?([^"]+)"?/);
                        if (match) filename = match[1];
                    }

                    // trigger download
                    var url  = window.URL.createObjectURL(blob);
                    var link = document.createElement("a");
                    link.href     = url;
                    link.download = filename;
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    window.URL.revokeObjectURL(url);

                    showExportAlert("success", exportType + " exported successfully.");

                    // close modal after short delay
                    setTimeout(function () {
                        $("#exportModal").modal("hide");
                    }, 1500);
                },
                error: function (xhr) {
                    var message = "Export failed. Please try again.";
                    try {
                        var json = JSON.parse(xhr.responseText);
                        if (json.message) message = json.message;
                    } catch (e) { }
                    showExportAlert("danger", message);
                },
                complete: function () {
                    $("#btnExportText").show();
                    $("#btnExportSpinner").hide();
                    $("#btnExport").prop("disabled", false);
                }
            });
        });

            // reset modal on close
            $("#exportModal").on("hidden.bs.modal", function () {
                $("#exportSearch").val("");
                $("#exportStatus").val("");
                $("#exportCountry").val("");
                $("#exportIncludeContacts").val("true");
                $("input[name='exportFormat'][value='Excel']").prop("checked", true);
                $("#exportAlert").hide();
                $("#exportSummary").hide();
            });

            function showExportAlert(type, message) {
                $("#exportAlert")
                    .removeClass("alert-success alert-danger")
                    .addClass("alert-" + type)
                    .text(message)
                    .show();
            }

            function getTimestamp() {
                var now = new Date();
                return now.getFullYear()
                    + pad(now.getMonth() + 1)
                    + pad(now.getDate())
                    + "_"
                    + pad(now.getHours())
                    + pad(now.getMinutes())
                    + pad(now.getSeconds());
            }

            function pad(n) { return n < 10 ? "0" + n : n; }

    $("#btnUpload").click(function () {
        var file = $("#fileUpload")[0].files[0];
        if (!file) {
            showImportAlert("danger", "Please select a file.");
            return;
        }

        var formData = new FormData();
        formData.append("file", file);

        $("#btnUploadText").hide();
        $("#btnUploadSpinner").show();
        $("#btnUpload").prop("disabled", true);
        $("#importAlert").hide();

        $.ajax({
            url: "@Url.Action("ImportCustomers", "Sales")",
            type: "POST",
            data: formData,
            processData: false,
            contentType: false,
            success: function (res) {
                if (res.status) {
                    showImportAlert("success", "Customers import successfully");
                    $("#fileUpload").val("");
                } else {
                    showImportAlert("danger", "Error while saving Customer");
                }
            },
            error: function () {
                showImportAlert("danger", "An unexpected error occurred. Please try again.");
            },
            complete: function () {
                $("#btnUploadText").show();
                $("#btnUploadSpinner").hide();
                $("#btnUpload").prop("disabled", false);
            }
        });
    });

    function showImportAlert(type, message) {
        $("#importAlert")
            .removeClass("alert-success alert-danger")
            .addClass("alert-" + type)
            .text(message)
            .show();
    }

    // Clear alert and file when modal is closed
    $("#importModal").on("hidden.bs.modal", function () {
        $("#importAlert").hide();
        $("#fileUpload").val("");
    });

