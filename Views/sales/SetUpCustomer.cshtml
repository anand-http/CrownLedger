            AmountOutstanding: $('#hdnAmtOutstng').val(),
            UnusedCredit: $('#hdnUnusedCredit').val(),
            Website: $('#txtWebsite').val(),
            Client_Status: status,
            Country: $('#hdnCountryID').val(),
            State: $('#hdnStateID').val(),
            Department: $('#hdnDepartmentID').val(),
            DefaultCurrency: $('#hdnCurrencyID').val(),
            Address1: $('#txtPAddress1').val(),
            Address2: $('#txtPAddress2').val(),
            CorrespondenceAddress1: $('#txtCAddress1').val(),
            CorrespondenceAddress2: $('#txtCAddress2').val(),
            City: $('#hdnCCityID').val(),
            City2: $('#hdnPCityID').val(),
            State2: $('#hdnPStateID').val(),
            Country2: $('#hdnPCountryID').val(),
            ZipCode: $('#txtPZip').val(),
            ZipCode2: $('#txtCZip').val(),
            BankCurrency: $('#txtBankCurrency').val(),
            AccountNumber: $('#txtAccountNumber').val(),
            Payee: $('#txtPayee').val(),
            BankName: $('#txtBankName').val(),
            IBAN_IFSC: $('#txtIFSC').val(),
            SWIFTCode: $('#txtSWIFT').val(),
            SORTCode: $('#txtSORT').val(),
            GST_VAT: $('#txtGST').val(),
            PAN: $('#txtPAN').val(),
            TaxCode: $('#txtTaxCode').val(),
            Records: $('#txtRecords').val(),
            Status: $('#StatusId').val()
        };
        //comment
        $.ajax({
            url: '@Url.Action("CreateCustomer", "Sales")',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(model),
            success: function (response) {
                if (response.success) {
                    alert('Customer saved successfully!');
                    // Optionally reload or update UI
                    $('#CreateCustomermodal').modal('hide');
                    location.reload();
                } else {
                    alert(response.message || 'An error occurred while saving the customer.');
                }
