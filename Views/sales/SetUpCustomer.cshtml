     $('#CreateCustomermodal').on('show.bs.modal', function (e) {
            var trigger = $(e.relatedTarget);

           //ADD MODE
         if (trigger.attr("id") === "btnAddCustomer") {
             $('#customerForm')
                 .find('input[type="text"], input[type="email"], input[type="hidden"]')
                 .not('#hdnEntityId')
                 .val('');

             // Uncheck all checkboxes
             $('#customerForm').find('input[type="checkbox"]').prop('checked', false);

             // Reset selects to first option
             $('#customerForm').find('select').prop('selectedIndex', 0);

             // Clear typeahead fields using the typeahead API
             var typeaheadFields = [
                 '#txtCountry', '#txtState', '#txtDepartment', '#txtCurrency',
                 '#txtPCity', '#txtPState', '#txtPCountry',
                 '#txtCCity', '#txtCState', '#txtCCountry',
                 '#txtTaxCode', '#txtCurrencyBD', '#txtTerm2'
             ];
             $.each(typeaheadFields, function (_, selector) {
                 var $el = $(selector);
                 // Clear via typeahead API if initialized, then force the DOM value
                 if ($el.data('typeahead') || $el.hasClass('tt-input')) {
                     $el.typeahead('val', '');
                 }
                 $el.val('');
             });

             // Remove extra payment terms, keep and reset the first
             var $paymentTerms = $('#CreateCustomermodal .payment-terms');
             $paymentTerms.not(':first').remove();
             $paymentTerms.first().find('.header-title').text('Payment Term 1');
             $paymentTerms.first().find('.default-payment-term').prop('checked', true);

             // Reset contact table to a single empty row
             var $contactBody = $('#contactTableBody');
             $contactBody.empty().append(buildContactRow(0, null));
             $('#txtDepart_0').typeheadAutoComplete(
                 'Core.mst_ContactType',
                 'Contyp',
                 $('#hdnDepartID_0')
             );

             $('#pills-tab .nav-link').removeClass('active');
             $('#pills-address-tab').addClass('active');
             $('.tab-pane').removeClass('show active');
             $('#pills-address').addClass('show active');

             $('#exampleModalLabel').text("Create a New Customer");
             return;
         }


           //Edit mode
         if (trigger.hasClass("editCustomer")) {
             var $trigger = $(e.relatedTarget);
