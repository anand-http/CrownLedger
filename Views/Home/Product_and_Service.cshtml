    <!-- Modal -->
    @Html.Partial("~/Views/Shared/_PartialCreateGoods.cshtml", new sp_GetProductAndService_Result { Type = "Goods" })


<script>

        var ProductnServices
        var selectedStatus = "";

        $(document).ready(function () {
        ProductnServices = $("#productservice").DataTable({
         "serverSide": true,
         "ajax": {
            "url": "@Url.Action("GetProdnServiceList")",
            "type": "POST",
            "datatype": "json",

             "data": function (d) {
                 d.icolelngth = 6;
                 d.statusFilter = selectedStatus;
             },
            "beforeSend": function() {

            },
            "complete": function () {
            }
           },
           createdRow: function (row, data, dataIndex) {
               $(row).attr('data-id', data.Id); // ← your PK column name
           },
        "columns": [
            { "data": "ItemCode", "name": "ItemCode", "autoWidth": true ,"visible": true, "class":"text-capitalize" },
            { "data": "ItemName", "name": "ItemName", "autoWidth": true,"visible": true, "class": "center"},
            { "data": "ItemDescription", "name": "ItemDescription", "autoWidth": true, "visible": true, "class": "center" },
            { "data": "SellingPrice", "name": "Selling_Price", "autoWidth": true, "visible": true, "class": "center" },
            { "data": "HSNCode", "name": "HSNCode", "autoWidth": true, "visible": true, "class": "center" },
            { "data": "UnitOfMeasurement", "name": "Unit_Of_Measurement", "autoWidth": true, "visible": true, "class": "text-capitalize"}
        ],

        "fnInitComplete": function (oSettings) {
            var j = 0;
        },
    });

        $('.search-input').on('keyup', function () {
            var value = this.value.trim();
            if (value.length >= 3 || value.length == 0) {
                ProductnServices.search(value).draw();
            }
        });

        $('.sort-by').on('click', function (e) {
                let currentDir = 'asc';
                e.preventDefault();
                let selectedSort = $(this).attr('data-status') || "";
                let selectedText = $(this).text();
                //sort by customer name
                if (selectedSort == 'IC') {
                    $(this).closest('.dropdown').find('.dropdown-toggle').text(selectedText + ' ');
                    ProductnServices.order([0, currentDir]).draw();
                }
                //sort by shipment date
                else if (selectedSort == 'IN') {
                    $(this).closest('.dropdown').find('.dropdown-toggle').text(selectedText + ' ');
                    ProductnServices.order([1, currentDir]).draw();

                }
                //sort by amount
                else if (selectedSort == 'ID') {
                    $(this).closest('.dropdown').find('.dropdown-toggle').text(selectedText + ' ');
                    ProductnServices.order([2, currentDir]).draw();

                }
                //sort by order number
                else if (selectedSort == 'HS') {
                    $(this).closest('.dropdown').find('.dropdown-toggle').text(selectedText + ' ');
                    ProductnServices.order([4, currentDir]).draw();

                }
                //sort by created by
                else if (selectedSort == 'R') {
                    $(this).closest('.dropdown').find('.dropdown-toggle').text(selectedText + ' ');
                    ProductnServices.order([3, currentDir]).draw();
                }
                else if (selectedSort == 'U') {
                    $(this).closest('.dropdown').find('.dropdown-toggle').text(selectedText + ' ');
                    ProductnServices.order([5, currentDir]).draw();
                }
            });
    });

        $(document).ready(function () {

            $('#txtPnsTaxCode').typeheadAutoComplete('CORE.mst_Tax', 'Tax', $('#hdnPnsTaxID'));
            $('#txtPnsPurcTaxCode').typeheadAutoComplete('CORE.mst_Tax', 'Tax', $('#hdnPnsPurcTaxID'));
            $('#txtPnsIncAcct').typeheadAutoComplete('ACCT.mst_GLMaster', 'GL', $('#hdnPnsIncAcctId'));
            $('#txtPnsExpAcct').typeheadAutoComplete('ACCT.mst_GLMaster', 'GL', $('#hdnPnsExpAcctId'));
            $('#txtPnsTaxAcct').typeheadAutoComplete('ACCT.mst_GLMaster', 'GL', $('#hdnPnsTaxAcctId'));
            $('#txtPnsVendor').typeheadAutoComplete('[PARTNER].[mst_Partner]', 'Partner', $('#hdnPnsVendorID'));
            setGoodsMode();  // default state

            // Goods radio clicked
            $('#goods').on('change', function () {
                setGoodsMode();
            });

            // Services radio clicked
            $('#service').on('change', function () {
                setServicesMode();
            });
        });
        // Taxability change handler — works for both Stock and Non-Stock tabs
        $(document).on('change', 'select[name="Taxability"]', function () {
            var selected = $(this).val();

            if (selected === 'Exempt' || selected === 'Non-GST') {
                hideTaxFields();
            } else {
                showTaxFields();
            }
        });

        function hideTaxFields() {
            // Sales - Tax Group
            $('#txtPnsTaxCode').prop('disabled', true);

            // Purchase - Input Tax Credit
            $('#txtPnsTaxAcct').prop('disabled', true);

            // Purchase - Tax Group
            $('#txtPnsPurcTaxCode').prop('disabled', true);
        }

        function showTaxFields() {
            // Sales - Tax Group
            $('#txtPnsTaxCode').prop('disabled', false);

            // Purchase - Input Tax Credit
            $('#txtPnsTaxAcct').prop('disabled', false);

            // Purchase - Tax Group
            $('#txtPnsPurcTaxCode').prop('disabled', false);
        }

        function setGoodsMode() {
            // First remove disabled from Stock tab, then activate it
            $('#pills-stock-tab').removeClass('disabled').removeAttr('tabindex').attr('aria-disabled', 'false');
            $('#pills-stock-tab').trigger('click');

            // Then disable Non-Stock tab
            $('#pills-non-stock-tab').addClass('disabled').attr('tabindex', '-1').attr('aria-disabled', 'true');
        }

        function setServicesMode() {
            // First remove disabled from Non-Stock tab, then activate it
            $('#pills-non-stock-tab').removeClass('disabled').removeAttr('tabindex').attr('aria-disabled', 'false');
            $('#pills-non-stock-tab').trigger('click');

            // Then disable Stock tab
            $('#pills-stock-tab').addClass('disabled').attr('tabindex', '-1').attr('aria-disabled', 'true');
        }

        $(".form-switch").click(function () {
            if ($(this).parent().hasClass("yes")) {
                $(this).parent().removeClass("yes");
                $(this).parent().addClass("no");
            } else {
                $(this).parent().removeClass("no");
                $(this).parent().addClass("yes");
            }
        });


        function SaveProductAndService() {

            // Determine active tab — Stock or Non-Stock
            var isStock = $('#pills-stock-tab').hasClass('active');

            // Item Type — G for Goods, S for Service
            var itemType = $('input[name="Type"]:checked').val() === 'Goods' ? 'G' : 'S';

            // Sub Type — based on active tab
            var subType = isStock ? 'Stock' : 'Non-Stock';

            var formData = {
                Id: $('#Id').val(),
                Type: itemType,                       // G or S

                // Common fields
                ItemCode: isStock ? $('input[name="ItemCode"]', '#pills-stock').val() : $('input[name="ItemCode"]', '#pills-non-stock').val(),
                ItemName: isStock ? $('#txtitempns').val() : $('input[name="ItemName"]', '#pills-non-stock').val(),
                ItemDescription: isStock ? $('#txtdescpns').val() : $('input[name="ItemDescription"]', '#pills-non-stock').val(),
                UnitOfMeasurement: isStock ? $('input[name="UnitOfMeasurement"]', '#pills-stock').val() : $('input[name="UnitOfMeasurement"]', '#pills-non-stock').val(),
                HSNCode: isStock ? $('#txtHSNpns').val() : $('input[name="HSNCode"]', '#pills-non-stock').val(),
                Taxability: isStock ? $('#pills-stock select[name="Taxability"]').val() : $('#pills-non-stock select[name="Taxability"]').val(),

                // Pricing
                SellingPrice: isStock ? $('input[name="SellingPrice"]', '#pills-stock').val() : $('input[name="SellingPrice"]', '#pills-non-stock').val(),
                CostPrice: isStock ? $('input[name="CostPrice"]', '#pills-stock').val() : $('input[name="CostPrice"]', '#pills-non-stock').val(),

                // Inventory (Stock only)
                InventoryAccount: isStock ? $('#hdnPnsInvAcctId').val() : null,
                InitialQtyOnHand: isStock ? $('input[name="InitialQtyOnHand"]').val() : null,
                AsOnDate: isStock ? $('input[name="AsOnDate"]').val() : null,
                ReorderPoint: isStock ? $('input[name="ReorderPoint"]').val() : null,

                // Sales details
                IncomeAccount: isStock ? $('#hdnPnsIncAcctId').val() : $('#pills-non-stock select[name="IncomeAccount"]').val(),
                SalesTaxGroup: isStock ? $('#hdnPnsTaxID').val() : $('#pills-non-stock select[name="SalesTaxGroup"]').val(),

                // Purchase details
                ExpenseAccount: isStock ? $('#hdnPnsExpAcctId').val() : $('#pills-non-stock select[name="ExpenseAccount"]').val(),
                InputTaxCredit: isStock ? $('#hdnPnsTaxAcctId').val() : $('#pills-non-stock select[name="InputTaxCredit"]').val(),
                PurchaseTaxGroup: isStock ? $('#hdnPnsPurcTaxID').val() : $('#pills-non-stock select[name="PurchaseTaxGroup"]').val(),
                Vendor: isStock ? $('#hdnPnsVendorID').val() : $('#pills-non-stock select[name="Vendor"]').val(),

                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            };

            // Validation
            if (!formData.ItemName || formData.ItemName.trim() === '') {
                alert('Item Name is required.');
                return;
            }
            if (!formData.SellingPrice || formData.SellingPrice.trim() === '') {
                alert('Selling Price is required.');
                return;
            }

            $.ajax({
                url: '@Url.Action("SaveProductAndService", "Home")',
                type: 'POST',
                data: formData,
                success: function (response) {
                    if (response.success) {
                        $('#CreateGoodsItems').modal('hide');
                        if (typeof productTable !== 'undefined') {
                            productTable.ajax.reload();
                        }
                        alert(response.message || 'Saved successfully.');
                    } else {
                        alert(response.message || 'Something went wrong.');
                    }
                },
                error: function (xhr) {
                    alert('Error: ' + xhr.statusText);
                }
            });
        }

</script>

</body>

