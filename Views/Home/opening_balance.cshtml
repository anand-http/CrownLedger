    <!-- ==================== MAIN SCRIPT ==================== -->
    <script>
        $(function () {

            // ─────────────────────────────────────────────
            // 1. DATE RANGE PICKER
            // ─────────────────────────────────────────────
            $('input[name="fiscaldate"]').daterangepicker({
                singleDatePicker: true,
                showDropdowns: true,
                minYear: 1901,
                maxYear: parseInt(moment().format('YYYY'), 10)
            });


            // ─────────────────────────────────────────────
            // 2. HELPER: BUILD SUB-ROW INPUT
            //    Reusable function to generate a sub-account input row
            // ─────────────────────────────────────────────
            function subRow(label) {
                return '<tr class="subtable">' +
                    '<td>' + label + '</td>' +
                    '<td class="text-center">--</td>' +
                    '<td><div class="input-group"><input type="text" class="form-control text-end sub-debit" placeholder="0.00"></div></td>' +
                    '<td><div class="input-group"><input type="text" class="form-control text-end sub-credit" placeholder="0.00"></div></td>' +
                    '</tr>';
            }

            function subTableHeader() {
                return '<tr class="subtable">' +
                    '<th>Accounts</th>' +
                    '<th class="text-center">Available Balance</th>' +
                    '<th class="datatable_right debit-table-row">Debit</th>' +
                    '<th class="datatable_right credit-table-row">Credit</th>' +
                    '</tr>';
            }

            function addAccountLink(modalTarget) {
                return '<tr class="subtable"><td colspan="4">' +
                    '<a href="#" data-bs-toggle="modal" data-bs-target="#' + modalTarget + '" class="add-vendor ms-0">' +
                    '<span class="icon"><img src="../assets/images/addicon.svg"></span>Add Another Account' +
                    '</a></td></tr>';
            }

            function wrapSubTable(innerRows) {
                return '<tr class="p-0 addnewrow"><td class="p-0" colspan="6">' +
                    '<table class="table mb-0"><tbody>' +
                    innerRows +
                    '</tbody></table></td></tr>';
            }


            // ─────────────────────────────────────────────
            // 3. SUB-ACCOUNT DATA
            //    All sub-account lists defined here — easy to update
            // ─────────────────────────────────────────────
            var subAccounts = {
                assets: {
                    modal: 'assetmodal',
                    rows: [
                        'Advance Tax', 'Employee Advance', 'Input CGST', 'Input IGST',
                        'Input SGST', 'Input Tax Credits', 'Prepaid Expenses',
                        'Reverse Charge Tax Input but not due', 'TDS Receivable',
                        'Petty Cash', 'Undeposited Funds', 'Furniture and Equipment',
                        'Inventory Asset'
                    ]
                },
                liability: {
                    modal: 'liabilitymodal',
                    rows: [
                        'Employee Reimbursements', 'GST Payable', 'Output CGST',
                        'Output IGST', 'Output SGST', 'Tax Payable', 'TDS Payable',
                        'Unearned Revenue', 'Construction Loans', 'Mortgages'
                    ]
                },
                equity: {
                    modal: 'Equitymodal',
                    rows: [
                        'Capital Stock', 'Distributions', 'Dividends Paid', 'Drawings',
                        'Investments', 'Opening Balance Offset', 'Owners Equity',
                        'Retained Earnings'
                    ]
                },
                income: {
                    modal: 'Incomemodal',
                    rows: [
                        'Discount', 'General Income', 'Interest Income', 'Late Fee Income',
                        'Other Charges', 'Sales', 'Shipping Charge'
                    ]
                },
                expense: {
                    modal: 'Expensemodal',
                    rows: [
                        'Advertising And Marketing', 'Automobile Expense', 'Bad Debt',
                        'Bank Fees and Charges', 'Consultant Expense', 'Contract Assets',
                        'Credit Card Charges', 'Depreciation And Amortisation',
                        'Depreciation Expense', 'IT and Internet Expenses',
                        'Janitorial Expense', 'Lodging', 'Meals and Entertainment',
                        'Merchandise', 'Office Supplies', 'Other Expenses', 'Postage',
                        'Printing and Stationery', 'Purchase Discounts',
                        'Raw Materials And Consumables', 'Rent Expense',
                        'Repairs and Maintenance', 'Salaries and Employee Wages',
                        'Telephone Expense', 'Transportation Expense', 'Travel Expense',
                        'Uncategorized', 'Cost of Goods Sold', 'Job Costing', 'Labor',
                        'Materials', 'Subcontractor', 'Exchange Gain or Loss'
                    ]
                },
                bank: {
                    modal: 'Bankmodal',
                    rows: ['Advance Tax']
                },
                cash: {
                    modal: 'Cashmodal',
                    rows: ['Advance Tax']
                }
            };

            // Builds a full sub-table HTML string for a given type key
            function buildSubTable(typeKey) {
                var data = subAccounts[typeKey];
                var rows = subTableHeader();
                $.each(data.rows, function (i, label) {
                    rows += subRow(label);
                });
                rows += addAccountLink(data.modal);
                return wrapSubTable(rows);
            }


            // ─────────────────────────────────────────────
            // 4. TOGGLE EXPAND ROWS
            //    Single unified handler — fixes scroll-to-top bug
            //    by using e.preventDefault() on all expand clicks
            // ─────────────────────────────────────────────
            var expandMap = {
                '.assets_control': 'assets',
                '.Liability_control': 'liability',
                '.Equity_control': 'equity',
                '.Income_control': 'income',
                '.Expense_control': 'expense',
                '.Bank_control': 'bank',
                '.Cash_control': 'cash'
            };

            $.each(expandMap, function (selector, typeKey) {
                $("#datatable1_wrapper tbody").on("click", selector, function (e) {
                    e.preventDefault();  // FIX: prevents scroll-to-top
                    e.stopPropagation();

                    var tr = $(this).closest("tr");
                    if (tr.next('tr.addnewrow').length) {
                        tr.next('tr.addnewrow').remove();
                    } else {
                        tr.after(buildSubTable(typeKey));
                    }
                    recalculateSummary();
                });
            });

            // Customer expand row (read-only transaction list, no debit/credit inputs)
            $("#datatable1_wrapper tbody").on("click", ".details-control-customer", function (e) {
                e.preventDefault();  // FIX: prevents scroll-to-top
                e.stopPropagation();

                var tr = $(this).closest("tr");
                if (tr.next('tr.addnewrow').length) {
                    tr.next('tr.addnewrow').remove();
                } else {
                    var TrRow =
                        '<tr class="p-0 addnewrow"><td class="p-0" colspan="6">' +
                        '<table class="display customize-table-style dataTable">' +
                        '<thead><tr><th>Customer</th><th>Currency</th><th>Debit</th><th>Credit</th></tr></thead><tbody>' +
                        '<tr><td>Aman Sharma</td><td>USD</td>' +
                        '<td><input type="text" class="form-control debit-input" value="125.00" /></td>' +
                        '<td><input type="text" class="form-control credit-input" value="1100.00" /></td></tr>' +
                        '<tr><td>Kapil Sharma</td><td>USD</td>' +
                        '<td><input type="text" class="form-control debit-input" value="154.00" /></td>' +
                        '<td><input type="text" class="form-control credit-input" value="1350.00" /></td></tr>' +
                        '<tr><td>Jaya Sharma</td><td>USD</td>' +
                        '<td><input type="text" class="form-control debit-input" value="100.00" /></td>' +
                        '<td><input type="text" class="form-control credit-input" value="1100.00" /></td></tr>' +
                        '</tbody></table></td></tr>';
                    tr.after(TrRow);
                }
            });

            // Vendor expand row (read-only transaction list, no debit/credit inputs)
            $("#datatable1_wrapper tbody").on("click", ".details-control-vendor", function (e) {
                e.preventDefault();  // FIX: prevents scroll-to-top
                e.stopPropagation();

                var tr = $(this).closest("tr");
                if (tr.next('tr.addnewrow').length) {
                    tr.next('tr.addnewrow').remove();
                } else {
                    var TrRow =
                        '<tr class="p-0 addnewrow"><td class="p-0" colspan="6">' +
                        '<table class="display customize-table-style dataTable">' +
                        '<thead><tr><th>Vendor</th><th>Currency</th><th>Debit</th><th>Credit</th></tr></thead><tbody>' +
                        '<tr><td>Aman Sharma</td><td>USD</td>' +
                        '<td><input type="text" class="form-control debit-input" value="125.00" /></td>' +
                        '<td><input type="text" class="form-control credit-input" value="1100.00" /></td></tr>' +
                        '<tr><td>Kapil Sharma</td><td>USD</td>' +
                        '<td><input type="text" class="form-control debit-input" value="154.00" /></td>' +
                        '<td><input type="text" class="form-control credit-input" value="1350.00" /></td></tr>' +
                        '<tr><td>Jaya Sharma</td><td>USD</td>' +
                        '<td><input type="text" class="form-control debit-input" value="100.00" /></td>' +
                        '<td><input type="text" class="form-control credit-input" value="1100.00" /></td></tr>' +
                        '</tbody></table></td></tr>';
                    tr.after(TrRow);
                }
            });

            // Generic .details-control toggle (data-target based)
            $(document).on('click', '.details-control', function (event) {
                if ($(event.target).is('a, button, input, select, label')) return;
                var targetId = $(this).data('target');
                $('#' + targetId).toggle();
            });


            // ─────────────────────────────────────────────
            // 5. LIVE SUMMARY RECALCULATION
            //    Totals + Adjustment + Grand Total auto-update
            //    on every debit/credit input change
            // ─────────────────────────────────────────────
            function recalculateSummary() {
                var totalDebit = 0;
                var totalCredit = 0;

                // Sum parent row inputs (Account Receivable, Asset, Liability etc.)
                $("#datatable1_wrapper > tbody > tr[role='row'] td:nth-child(3) input.form-control").each(function () {
                    totalDebit += parseFloat($(this).val()) || 0;
                });
                $("#datatable1_wrapper > tbody > tr[role='row'] td:nth-child(4) input.form-control").each(function () {
                    totalCredit += parseFloat($(this).val()) || 0;
                });

                // Sum expanded sub-row inputs (Bank, Cash, Asset sub-accounts etc.)
                $("tr.addnewrow input.sub-debit").each(function () {
                    totalDebit += parseFloat($(this).val()) || 0;
                });
                $("tr.addnewrow input.sub-credit").each(function () {
                    totalCredit += parseFloat($(this).val()) || 0;
                });

                // Opening Balance Adjustment = the side needed to balance
                var adjDebit = 0, adjCredit = 0;
                var diff = totalDebit - totalCredit;
                if (diff > 0) adjCredit = diff;       // excess debit → add to credit side
                else adjDebit = Math.abs(diff); // excess credit → add to debit side

                var grandDebit = totalDebit + adjDebit;
                var grandCredit = totalCredit + adjCredit;

                // Update the 3 summary rows
                $(".summary .summary-row:nth-child(1) .debit-balance").text(totalDebit.toFixed(2));
                $(".summary .summary-row:nth-child(1) .credit-balance").text(totalCredit.toFixed(2));

                $(".summary .summary-row:nth-child(2) .debit-balance").text(adjDebit.toFixed(2));
                $(".summary .summary-row:nth-child(2) .credit-balance").text(adjCredit.toFixed(2));

                $(".summary .total-row .debit-balance").text(grandDebit.toFixed(2));
                $(".summary .total-row .credit-balance").text(grandCredit.toFixed(2));
            }

            // Trigger recalc on any debit/credit input change (parent + dynamically added sub-rows)
            $(document).on("input", "#datatable1_wrapper .form-control.text-end, tr.addnewrow .form-control.text-end", function () {
                recalculateSummary();
            });

            // Run once on load to initialize display
            recalculateSummary();


            // ─────────────────────────────────────────────
            // 6. FILE UPLOAD LABEL UPDATE
            // ─────────────────────────────────────────────
            $("form").on("change", ".file-upload-field", function () {
                $(this).parent(".file-upload-wrapper").attr("data-text", $(this).val().replace(/.*(\/|\\)/, ''));
            });


            // ─────────────────────────────────────────────
            // 7. IMPORT FILE TOGGLE (Upload vs Form section)
            // ─────────────────────────────────────────────
            $(".importfile").on("click", function () {
                $(".Openingupload-sec").toggle();
                $(".Openingform-sec").toggle();
            });
        });
        // ─────────────────────────────────────────────
        // SINGLE MODAL SAVE FUNCTION
        // Reads all inputs from the modal containing
        // the clicked button and posts to the server
        // ─────────────────────────────────────────────
        function saveModalData(btn) {
            var modalType = $(btn).data('modal-type');
            var $modal = $(btn).closest('.modal');
            var $form = $modal.find('.Openingform-sec');

            // Collect all inputs & selects inside the form section
            var data = { type: modalType };
            $form.find('input, select').each(function () {
                var label = $(this).closest('.form-floating').find('label').text()
                    .replace('*', '').trim();
                var key = label.toLowerCase().replace(/\s+/g, '_');
                data[key] = $(this).val();
            });

            // Validate — check required fields (labels with *)
            var isValid = true;
            $form.find('input, select').each(function () {
                var isRequired = $(this).closest('.form-floating').find('label').text().includes('*');
                if (isRequired && !$(this).val().trim()) {
                    $(this).addClass('is-invalid');
                    isValid = false;
                } else {
                    $(this).removeClass('is-invalid');
                }
            });

            if (!isValid) {
                Swal.fire('Validation', 'Please fill all required fields.', 'warning');
                return;
            }

            // Map of modal type → controller action
            var actionMap = {
                'customer': '/Home/SaveCustomerOpeningBalance',
                'vendor': '/Home/SaveVendorOpeningBalance',
                'asset': '/Home/SaveAssetOpeningBalance',
                'liability': '/Home/SaveLiabilityOpeningBalance',
                'equity': '/Home/SaveEquityOpeningBalance',
                'income': '/Home/SaveIncomeOpeningBalance',
                'expense': '/Home/SaveExpenseOpeningBalance'
            };

            var url = actionMap[modalType];
            if (!url) {
                Swal.fire('Error', 'Unknown modal type: ' + modalType, 'error');
                return;
            }

            $.ajax({
                url: url,
                type: 'POST',
                data: data,
                beforeSend: function () {
                    $(btn).prop('disabled', true).text('Saving...');
                },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: res.message,
                            timer: 1500,
                            showConfirmButton: false
                        }).then(function () {
                            $modal.modal('hide');         // close modal
                            $form[0].reset();             // clear form
                            $form.find('.is-invalid').removeClass('is-invalid');
                        });
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                },
                error: function (xhr) {
                    Swal.fire('Error', xhr.responseText || 'Something went wrong.', 'error');
                },
                complete: function () {
                    $(btn).prop('disabled', false).text('Save');
                }
            });
        }
    </script>


