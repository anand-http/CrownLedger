        // ── Add New Row to Details table ──
        let detailRowIndex = 0;

        function addDetailRow() {
            const rowCount = $('#detailsTableBody tr').length + 1; // ── auto increment ──

            const row = `
                <tr role="row">
                    <td>
                        <div class="input-group">
                            <input input type="text" class="form-control py-1" id="txtgrptax_${rowCount}" placeholder="" aria-label="Search" aria-describedby="addon-wrapping">
                            <input type="hidden" id="hdngrptaxid_${rowCount}" />
                        </div>
                    </td>
                    <td>
                        <div class="input-group">
                            <input  type="text" class="form-control py-1" placeholder="" id="txtgrptaxrate_${rowCount}" aria-label="Search" aria-describedby="addon-wrapping">
                        </div>
                    </td>
                    <td>
                        <div class="input-group">
                            <input  type="text" class="form-control py-1" placeholder="" id="txtTaxAcctDisplay_${rowCount}" aria-label="Search" aria-describedby="addon-wrapping">
                            <input type="hidden" id="hdnTaxAcct_${rowCount}" />
                        </div>
                    </td>
                    <td>
                        <div class="input-group">
                            <input  type="text" class="form-control py-1" placeholder="" id="txtTaxCNAcctDisplay_${rowCount}" aria-label="Search" aria-describedby="addon-wrapping">
                            <input type="hidden" id="hdnTaxCNAcct_${rowCount}" />
                        </div>
                    </td>
                    <td>
                        <button type="button" class="btn btn-sm btn-danger" onclick="removeDetailRow(this)">
                            <i class="fa fa-trash"></i>
                        </button>
                    </td>
                </tr>`;
            $('#detailsTableBody').append(row);

            $(`#txtTaxAcctDisplay_` + rowCount).typeheadAutoComplete('ACCT.mst_GLMaster', 'GL', $(`#hdnTaxAcct_` + rowCount));
            $(`#txtTaxCNAcctDisplay_` + rowCount).typeheadAutoComplete('ACCT.mst_GLMaster', 'GL', $(`#hdnTaxCNAcct_` + rowCount));
            $('#txtgrptax_' + rowCount).typeheadAutoComplete('mst_Tax_GST', 'Type', $('#hdngrptaxid_' + rowCount));

            $('#txtgrptax_' + rowCount).on('typeahead:selected', function (evt, item) {
                setTimeout(function () {
                    const factor = item.Code; // P = Percentage, A/Abs = Absolute
                    const rate = item.Selling_Price;

                    if (factor === 'P') {
                        $("#txtgrptaxrate_" + rowCount).val(rate + '%');
                    } else {
                        $("#txtgrptaxrate_" + rowCount).val(rate);
                    }
                }, 400);
            });
        }

        // ── Remove Row ──
        function removeDetailRow(btn) {
            // ── Prevent removing the last row ──
            if ($('#detailsTableBody tr').length === 1) {
                showToast("At least one detail row is required.", "error");
                return;
            }
            $(btn).closest('tr').remove();
        }


        // ── Clear TDS form on modal close ──
        function clearTdsForm() {
            $('#tdsTaxCode').val('');
            $('#tdsTdsType').val('');
            $('#tdsTdsSection').val('');
            $('#tdsTdsRate').val('');
            $('#tdsTdsEffectiveDate').val('');
            $('#tdsThresholdLimit').val('');
            $('#tdsLtdcApplied').prop('checked', false);
            $('#tdsLtdcEffectiveDate').val('');
            $('#tdsLtdcEffectiveAmount').val('');
            $('#tdsLedgerAccount').val('');
        }

        // ── Clear detail rows on modal close ──
        function clearDetailRows() {
            detailRowIndex = 0;
            $('#detailsTableBody').empty();
            addDetailRow(); // reset with one empty row
        }

        $(function () {
            $('input[name="fiscaldate"]').daterangepicker({
                singleDatePicker: true,
                showDropdowns: true,
                minYear: 1901,
                maxYear: parseInt(moment().format('YYYY'), 10)
            }, function (start, end, label) {
                var years = moment().diff(start, 'years');
            });
        });

        $(function () {
            $('input[name="daterange"]').daterangepicker(
                {
                    ssingleDatePicker: 'true',
                    showShortcuts: 'false',
                    showTopbar: 'false'
                }
            );
        });

        $(".form-switch").click(function () {
            if ($(this).parent().hasClass("yes")) {
                $(this).parent().removeClass("yes");
                $(this).parent().addClass("no");
            } else {
                $(this).parent().removeClass("no");
                $(this).parent().addClass("yes");
            }
        });


        // ─── Single Save Function for GST + TDS + Others ────────────────────────────
        function saveTaxData(taxType) {

                let payload = {};
                let url = "";

                if (taxType === "GST") {
                    const isRegistered = $('#gstYes').is(':checked'); // ── Check Yes/No toggle ──

                    if (isRegistered) {
                        const gstin = $('#gstin').val().trim();
                        const regDate = $('#registrationDate').val().trim();
                        if (!gstin) { showToast("GSTIN is required.", "error"); return; }
                        if (!regDate) { showToast("Registration Date is required.", "error"); return; }
                    }

                    // ── Detect which modal triggered the save ──
                    const isGroupModal = $('#newtaxgroup').hasClass('show');

                    if (isGroupModal) {
                        // ── Collect detail rows from the table ──
                        const details = [];
                        $('#detailsTableBody tr').each(function (index) {
                            const rowNum = index + 1;
                            const row = {
                                AssociatedTax: $('#hdngrptaxid_' + rowNum).val()?.trim() ?? '',
                                TaxRate: $('#txtgrptaxrate_' + rowNum).val()?.trim() ?? '',
                                TaxAccount: $('#hdnTaxAcct_' + rowNum).val()?.trim() ?? '',
                                TaxAccountCreditNote: $('#hdnTaxCNAcct_' + rowNum).val()?.trim() ?? ''
                            };

                            if (row.AssociatedTax || row.TaxRate || row.TaxAccount || row.TaxAccountCreditNote) {
                                details.push(row);
                            }
                        });

                        if (details.length === 0) {
                            showToast("Please add at least one detail row.", "error");
                            return;
                        }

                        payload = {
                            Tax_ID: 0,
                            Tax_Code: $('#newtaxgroup #txtGrpTaxCode').val().trim(),
                            Tax_Desc: $('#newtaxgroup #txtGrpTaxGroup').val().trim(),
                            Tax_type: $('#newtaxgroup #txtGrpTaxType').val().trim(),
                            Tax_Value: $('#newtaxgroup #txtGrpTaxRate').val().trim(),
                            ComputationBasis: parseInt($('#hdnGstCompTypeid').val()) || 0,
                            Active: true,
                            TaxCategory: "GST",
                            Isgroup: true,
                            Details: details   // ── detail rows included here ──
                        };
                    } else {
                        // ── Single Tax payload (from #addNewtax) ──
                        payload = {
                            Tax_ID: $('#gstModalTaxID').val(),
                            Tax_Code: $('#txttaxCode').val().trim(),
                            Tax_Desc: $('#txttaxName').val().trim(),
                            Tax_Value: $('#txtRate').val().trim(),
                            EffectiveFrom: isRegistered ? $('#registrationDate').val().trim() : null,
                            Is_InterState: isRegistered ? $('input[name="inlineRadioOptions"]:checked').val() === 'option1' : false,
                            Tax_type: $('#txtGstTaxType option:selected').text(),
                            ComputationBasis: parseInt($('#gstModalComputationBasis').val()) || 0,
                            Active: true,
                            IsRegistered: isRegistered,  // ── send to backend ──
                            TaxCategory: "GST",
                            IsGroup: false
                        };
                    }

                    url = '@Url.Action("SaveTax", "Home")';
                }
                else if (taxType === "TDS") {
                    payload = {
                        Tax_Include:        $('#icaccount').is(':checked'),
                        Tax_Code:           $('#tdsTaxCode').val(),
                        TdsType:            $('#hdntdstypeid').val(),
                        TDS_Section:        $('#tdsTdsSection').val(),
                        Tax_Value:          $('#tdsTdsRate').val(),
                        Threshold_Limit:    parseFloat($('#tdsThresholdLimit').val()) || null,
                        EffectiveAmount:    parseFloat($('#tdsLtdcEffectiveAmount').val()) || null,
                        LTDC_EffectiveDate: $('#tdsLtdcEffectiveDate').val(),
                        EffectiveFrom:      $('#tdsTdsEffectiveDate').val(),
                        LedgerAccount:      parseInt($('#tdsLedgerAccount').val()) || null,
                        CertificateNo:      $('#tdsLtdcertificateno').val(),
                        TaxCategory:        "TDS"
                    };
                    url = '@Url.Action("SaveTax", "Home")';

                }
                else if (taxType === "OTHER") {
                    payload = {
                        Tax_ID: $('#otherModalTaxID').val(),
                        Tax_Code: $('#txtothtaxcode').val(),         // Tax Code
                        Tax_Desc: $('#txtothtaxDesc').val(),         // Description (text input)
                        Tax_factor: $('#txtothtaxfactor').val(),       // Factor dropdown
                        ComputationBasis: $('#hdntcomptypeid').val(),        // Computation Basis hidden
                        Tax_GLIN: parseInt($('#hdntaxInAcctid').val()) || null,   // Tax In Account hidden
                        Tax_GLOUT: parseInt($('#hdntaxoutAcctid').val()) || null,  // Tax Out Account hidden
                        Tax_type:   $('#txtothTaxType').val(),       // Tax Type hidden
                        Tax_Value: $('#txtothTaxrate').val(),         // Tax Rate
                        EffectiveFrom: $('#txteffectdate').val(),         // Effective From
                        Active: $('#icaccount').is(':checked'),    // Active toggle
                        TaxCategory: "OTHER"
                    };
                    url = '@Url.Action("SaveTax", "Home")';
                }

            $.ajax({
                url: url,
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(payload),
                beforeSend: function () { toggleLoader(true); },
                success: function (res) {
                    toggleLoader(false);
                    if (res.success) {
                        swalValidationAlert(res.message || "Saved successfully.", "success").then(function () {
                            if (taxType === "GST") {
                                $('#addNewtax').modal('hide');
                                gstTable.ajax.reload(null, false);
                            } else if (taxType === "TDS") {
                                $('#CreateTdsCode').modal('hide');
                                tdsTable.ajax.reload(null, false);
                            } else {
                                $('#newtaxcode').modal('hide');
                                othersTable.ajax.reload(null, false);
                            }
                            resetModalFields(taxType);
                            window.location.href = "@Url.Action("maintain_tax_details", "Home")";
                        });
                    } else {
                        swalValidationAlert(res.message || "Something went wrong.", "error");
                    }
                },
                error: function (xhr) {
                    toggleLoader(false);
                    swalValidationAlert("Server error: " + xhr.statusText, "error");
                }
            });
            }

        // ─── Reset Modal Fields After Save ──────────────────────────────────────────
        function resetModalFields(taxType) {
            if (taxType === "GST") {
                $('#gstModalTaxID, #gstModalTaxGroup, #gstModalTaxType, #gstModalTaxRate, #gstModalComputationBasis').val('');
                $('#gstModalActive').prop('checked', false);
            } else if (taxType === "TDS") {
                $('#tdsModalTaxID, #tdsModalCode, #tdsModalType, #tdsModalSection, #tdsModalRate, #tdsModalThreshold, #tdsModalLedger').val('');
                $('#tdsModalActive').prop('checked', false);
            } else {
                $('#otherModalTaxID, #otherModalCode, #otherModalDesc, #otherModalFactor, #otherModalTaxIn, #otherModalTaxOut, #otherModalWithHold, #otherModalType').val('');
                $('#otherModalActive').prop('checked', false);
            }
        }

        // ─── Helpers ─────────────────────────────────────────────────────────────────
        function showLoader(show) {
            show ? $('#loader').show() : $('#loader').hide();
        }

        function toggleLoader(show) {
            if (show) $("#loader").removeClass("hide");
            else $("#loader").addClass("hide");
        }

        $(document).ready(function () {


            $('#framework').multiselect({
                nonSelectedText: 'Select Framework',
                enableFiltering: true,
                enableCaseInsensitiveFiltering: true,
                buttonWidth: '400px'
            });
        });
    </script>
</body>

