    <script>
        var gstTable;
        var selectedStatus = "";

            $(document).ready(function () {

            // ── 1. Currencies DataTable (server-side) ────────────────────────────────
            currencytable = $("#currencytable").DataTable({
                "serverSide": true,
                "ajax": {
                    "url": "@Url.Action("GetCurrencyList", "Home")",
                    "type": "POST",
                    "datatype": "json",
                    "data": function (d) {
                        d.statusFilter = selectedStatus;
                        d.icolelngth = 9;
                    },
                    "dataSrc": function (json) {
                        // Reload exchange rate DataTable with fresh data
                        exchangeRateData = json.data.ExchangeRate || [];
                        if (exchangeratetable) {
                            exchangeratetable.clear().rows.add(exchangeRateData).draw();
                        }
                        return json.data.CurrencyList;
                    }
                },
                createdRow: function (row, data, dataIndex) {
                    $(row).attr('data-id', data.Curncy_ID);
                },
                "columns": [
                    {
                        "data": "Curncy_Code", "name": "Curncy_Code", "autoWidth": true,
                        render: function (data, type, row) {
                            return `<a href="#" class="currency-row-link" data-id="${row.Curncy_ID}"
                                        data-bs-toggle="modal" data-bs-target="#addNewCurrency">
                                        ${data}
                                    </a>`;
                        }
                    },
                    { "data": "Curncy_Desc",    "name": "Curncy_Desc",    "autoWidth": true },
                    { "data": "Curncy_Symbol",  "name": "Curncy_Symbol",  "autoWidth": true },
                    { "data": "Curncy_Major",   "name": "Curncy_Major",   "autoWidth": true },
                    { "data": "Curncy_Minor",   "name": "Curncy_Minor",   "autoWidth": true },
                    { "data": "Curncy_Format",  "name": "Curncy_Format",  "autoWidth": true },
                    { "data": "Curncy_Decimal", "name": "Curncy_Decimal", "autoWidth": true },
                    {
                        "data": "Active", "name": "Active", "autoWidth": true,
                        render: function (data, type, row) {
                            const checked = data ? 'checked' : '';
                            return `<div class="display-label yes">
                                        <div class="form-switch">
                                            <input class="form-check-input currency-status-toggle"
                                                   type="checkbox" data-id="${row.Curncy_ID}" ${checked}>
                                        </div>
                                    </div>`;
                        }
                    }
                ]
            });

            // ── 2. Currencies Rate DataTable (client-side) ───────────────────────────
            var exchangeRateData = [];

            exchangeratetable = $("#exchangeratetable").DataTable({
                "serverSide": false,
                "data": exchangeRateData,
                "columns": [
                    { "data": "FromCurrency",           "name": "FromCurrency",           "autoWidth": true },
                    { "data": "ToCurrency",             "name": "ToCurrency",             "autoWidth": true },
                    { "data": "RateType",               "name": "RateType",               "autoWidth": true },
                    {
                        "data": "EffectiveDate", "name": "EffectiveDate", "autoWidth": true,
                        render: function (data, type, row) {
                            if (!data) return '';
                            // Handle ASP.NET /Date(ticks)/ format
                            var match = /\/Date\((\d+)\)\//.exec(data);
                            var date = match ? new Date(parseInt(match[1])) : new Date(data);
                            if (isNaN(date)) return '';
                            if (type === 'display' || type === 'filter') {
                                return date.toLocaleDateString('en-GB', {
                                    day: '2-digit', month: '2-digit', year: 'numeric'
                                }).replace(/\//g, '-');
                            }
                            return date.getTime();
                        }
                    },
                    { "data": "MultDiv",                "name": "MultDiv",                "autoWidth": true },
                    { "data": "ExchangeRate",           "name": "ExchangeRate",           "autoWidth": true },
                    { "data": "RateReciprocal",         "name": "RateReciprocal",         "autoWidth": true },
                    { "data": "CurrencyUnitEquivalents","name": "CurrencyUnitEquivalents","autoWidth": true }
                ],
                "language": {
                    "emptyTable": "No matching records found"
                }
            });

        });


        $(function() {
          $('input[name="fiscaldate"]').daterangepicker({
            singleDatePicker: true,
            showDropdowns: true,
            minYear: 1901,
            maxYear: parseInt(moment().format('YYYY'),10)
          }, function(start, end, label) {
            var years = moment().diff(start, 'years');
          });
        });

        $(function() {
                    $('input[name="daterange"]').daterangepicker(
                        {
                            ssingleDatePicker: 'true',
                            showShortcuts: 'false',
                            showTopbar: 'false'
                        }
                    );
                });


        $('#datatable1').DataTable({
                "columnDefs": [
                    {
                        "targets": -1,
                        "orderable": false
                    }
                ],
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "Search..."
                },
                fixedHeader: {
                    header: true,
                },
                "dom": '<"top"<"toolbar">tf<"clear">>rt<"bottom"lip<"clear">>'
            });

         $(".form-switch").click(function () {
            if ($(this).parent().hasClass("yes")) {
              $(this).parent().removeClass("yes");
              $(this).parent().addClass("no");
            } else {
              $(this).parent().removeClass("no");
              $(this).parent().addClass("yes");
            }
          });

      $(document).ready(function () {

          $('#framework').multiselect({
            nonSelectedText: 'Select Framework',
            enableFiltering: true,
            enableCaseInsensitiveFiltering: true,
            buttonWidth:'400px'
          });
      });
    </script>
