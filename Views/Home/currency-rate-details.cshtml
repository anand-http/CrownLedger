    <script>
          $(document).ready(function () {
              $(`#txtfromcurr`).typeheadAutoComplete('[Core].[mst_Currency]', 'Curncy', $(`#hdnfromcurrid`));
              $(`#txttocurr`).typeheadAutoComplete('[Core].[mst_Currency]', 'Curncy', $(`#hdntocurrid`));
              $(`#txtratetype`).typeheadAutoComplete('[Core].[mst_ExchangeType]', 'ExType', $(`#hdnratetypeid`));

          });

        function selectMultDiv(value) {
            $('#hdnmultdiv').val(value);
            $('#multDivLabel').text(value); // updates the visible label too
        }

        function SaveExchangeRate() {
            // Collect values
            const fromCurrId = $('#hdnfromcurrid').val();
            const fromCurr = $('#txtfromcurr').val().trim();
            const toCurrId = $('#hdntocurrid').val();
            const toCurr = $('#txttocurr').val().trim();
            const rateTypeId = $('#hdnratetypeid').val();
            const rateType = $('#txtratetype').val().trim();
            const efffromDate = $('input[name="fiscalfromdate"]').val().trim();
            const efftoDate = $('input[name="fiscaltodate"]').val().trim();
            const rate = $('#txtcurrencyrate').val().trim();
            const multDiv = $('#hdnmultdiv').val(); // "Multiply" or "Divide"

            // Validation
            if (!fromCurr || !fromCurrId) {
                Swal.fire({ icon: "error", text: "Please select a From Currency." });
                return;
            }
            if (!toCurr || !toCurrId) {
                Swal.fire({ icon: "error", text: "Please select a To Currency." });
                return;
            }
            if (!rateType || !rateTypeId) {
                Swal.fire({ icon: "error", text: "Please select a Rate Type." });
                return;
            }
            if (!efffromDate) {
                Swal.fire({ icon: "error", text: "Please select a From Effective Date." });
                return;
            }
            if (!efftoDate) {
                Swal.fire({ icon: "error", text: "Please select a To Effective Date." });
                return;
            }
            if (!rate || isNaN(rate) || parseFloat(rate) <= 0) {
                Swal.fire({ icon: "error", text: "Please Enter exchange Rate." });
                return;
            }
            if (!multDiv) {
                Swal.fire({ icon: "error", text: "Please select Multiply or Divide." });
                return;
            }

            const payload = {
                FromCurrencyId: fromCurrId,
                ToCurrencyId: toCurrId,
                CurrencyRateTypeId: rateTypeId,
                EffectivefromDate: efffromDate,
                EffectivetoDate: efftoDate,
                CurrencyRate: parseFloat(rate),
                MultDiv: multDiv
            };

            $.ajax({
                url: "@Url.Action("SaveExchangeRate", "Home")",
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                beforeSend: function () {
                    $('#btnSave').prop('disabled', true).text('Saving...');
                },
                success: function (response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: response.message,
                            timer: 1500,
                            showConfirmButton: false
                        }).then(function () {
                            window.location.href = '@Url.Action("maintain_currency_details", "Home")';
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: response.message
                        });
                    }
                },
                error: function (xhr) {
                    toastr.error('An error occurred: ' + (xhr.responseJSON?.message || xhr.statusText));
                },
                complete: function () {
                    $('#btnSave').prop('disabled', false).text('Save');
                }
            });
        }

        function ResetExchangeRateForm() {
            $('#txtfromcurr, #hdnfromcurrid').val('');
            $('#txttocurr,   #hdntocurrid').val('');
            $('#txtratetype, #hdnratetypeid').val('');
            $('input[name="fiscaldate"]').val('');
            $('#txtcurrencyrate').val('');
            $('#hdnmultdiv').val('');
            $('.dropdown-toggle').text('Select');
