        $("#datatable1_wrapper tbody").on("click", ".details-control", function () {
            var tr = $(this).closest("tr");

            if (tr.next('tr.addnewrow').length) {
                tr.next('tr.addnewrow').remove();
            } else {
                let TrRow = '<tr class="p-0 addnewrow"><td class="p-0" colspan="6"><table class="table mb-0"><tbody><tr class="subtable"><th>GL Code</th><th>GL Name</th><th>Branch</th><th>Department</th><th>Currency</th><th>IC Account</th><th>Control Account</th><th>Bank Account</th><th>Action</th><th></th></tr><tr class="subtable"><td>10001</td><td>Advertisement</td><td>Dubai</td><td>Admin</td><td>USD</td><td>No</td><td>No</td><td>No</td><td><div class="dropdown"><a class="form-select py-1 dropdown-toggle text-decoration-none" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false"><span class="">Select</span></a><ul class="dropdown-menu"><li><a class="dropdown-item" href="#">Account History</a></li><li><a class="dropdown-item" href="#">Edit Details</a></li><li><a class="dropdown-item" href="#">Mark as Inactive</a></li></ul></div></td><td><div class="d-flex justify-content-between"><span class="edit cursor" data-bs-toggle="modal" data-bs-target="#glcodemodal"><img src="~/assets/images/edit-icon.svg"></span></div></td></tr>';
                tr.after(TrRow);
            }
            //var row = table.row(tr);

            // if (row.child.isShown()) {
            //       row.child.hide();
            //       tr.removeClass("shown");
            //     } else {
            //       row.child(format(row.data()), "p-0").show();
            //       tr.addClass("shown");
            //     }
        });


    </script>
    <script>
        $(document).ready(function () {
            $('#datatable1_wrapper').DataTable({
                pagingType: 'full_numbers',
            });
        });
    </script>
    <script>
        $(".form-switch").click(function () {
            if ($(this).parent().hasClass("yes")) {
                $(this).parent().removeClass("yes");
                $(this).parent().addClass("no");
            } else {
                $(this).parent().removeClass("no");
                $(this).parent().addClass("yes");
            }
        });
    </script>

</body>

