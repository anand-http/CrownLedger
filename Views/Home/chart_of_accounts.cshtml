    @Html.Partial("~/Views/Shared/_PartialGlCode.cshtml", new fintech.GetAllChartOfAccounts_Result())

<script>
        var chartofaccounts
        var selectedStatus = "";

        $(document).ready(function () {

            $('#txtCOACurrency').typeheadAutoComplete('[Core].[mst_Currency]', 'Curncy', $('#hdnCOACurrencyId'));
            $('#txtCOAdept').val('').typeheadAutoComplete('CORE.mst_Department', 'Deptmt', $('#hdnCOADept'));
            $('#txtCOAbranch').val('').typeheadAutoComplete('CORE.mst_Branch', 'Branch', $('#hdnCOAbranch'));

       chartofaccounts = $("#chartofaccounts").DataTable({
         "serverSide": true,
         "ajax": {
            "url": "@Url.Action("GetAccountList")",
            "type": "POST",
            "datatype": "json",

             "data": function (d) {
                 d.icolelngth = 5;
                 d.statusFilter = selectedStatus;
             },
            "beforeSend": function() {

            },
            "complete": function () {
            }
           },
           createdRow: function (row, data, dataIndex) {
               $(row).attr('data-id', data.GL_ID); // ← your PK column name
           },
        "columns": [
            { "data": "GL_CODE", "name": "GL_CODE", "autoWidth": true ,"visible": true, "class":"text-capitalize" },
            { "data": "GL_DESC", "name": "GL_DESC", "autoWidth": true,"visible": true, "class": "center"},
            { "data": "GL_CLASS", "name": "GL_CLASS", "autoWidth": true, "visible": true, "class": "center" },
            { "data": "Group_desc", "name": "Group_desc", "autoWidth": true, "visible": true, "class": "center" },
            {"data": "Active", "name": "Active", "autoWidth": true, "visible": true, "class": "text-capitalize", render: function (data, index, row) {

                    return `<td class="datatable_right">
                                <div class="action-btn border-action gl-theme-clr py-1 px-2 editGL" data-id="${row.GL_ID}" data-bs-toggle="modal" data-bs-target="#glcodemodal">
                                    <svg class="me-2" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation" focusable="false" style="display: block; fill: none; height: 12px; width: 12px; stroke: currentcolor; stroke-width: 5.33333; overflow: visible;"><path d="m2 16h28m-14-14v28"></path></svg>
                                    Add GL Code
                                </div>
                            </td>
              </div>`
                }
            }
        ],

        "fnInitComplete": function (oSettings) {
            var j = 0;
        },
    });

        $('.search-input').on('keyup', function () {
            var value = this.value.trim();
            if (value.length >= 3 || value.length == 0) {
                Mytable.search(value).draw();
            }
        });

        $('.account_dropdown .status-option').on('click', function (e) {
            e.preventDefault();
            selectedStatus = $(this).attr('data-status') || "";
            var selectedText = $(this).text();
            $(this).closest('.dropdown').find('.dropdown-toggle').text(selectedText + ' ');
            Mytable.draw();
        });
});
        $(document).on('click', '.editGL', function () {
            var tr = $(this).closest('tr');
        var data = chartofaccounts.row(tr).data();
            if (!data) return;

        // Set modal title
        $('#glcodemodal .modal-title').text(data.GL_DESC + '_' + data.GL_CODE);

        // Populate fields by ID
        $('#GL_ID').val($(this).data('id'));
        $('#GL_CODE').val(data.GL_CODE);
        $('#Active').val(data.Active);
        $('#Curncy_ID').val(data.Curncy_ID);
        $('#currency-input').val(data.Currency);
        $('#glcode-input').val(data.GL_CODE || '');
        $('#description-input').val(data.GL_DESC || '');
        $('#icaccount-checkbox').prop('checked', data.GL_IC === true).trigger('change');
        $('#controlaccount-checkbox').prop('checked', data.GL_Control === true).trigger('change');
        $('#bankaccount-checkbox').prop('checked', data.GL_Bank === true).trigger('change');
        $('#activeaccount-checkbox').prop('checked', data.ActiveAccount === true).trigger('change');
        setRadio('GL_CLASS', data.GL_CLASS);
        setRadio('GL_G_Posting', data.GL_G_Posting);
        setRadio('GL_P_Payment', data.GL_P_Payment);
        setRadio('GL_P_Debit', data.GL_P_Debit);
        setRadio('GL_P_Invoice', data.GL_P_Invoice);
        setRadio('GL_R_Reciept', data.GL_R_Reciept);
        setRadio('GL_R_Credit', data.GL_R_Credit);
        setRadio('GL_R_Invoice', data.GL_R_Invoice);

         $('#txtCOAbranch').val(data.Branch || '');
         $('#hdnCOAbranch').val(data.GL_BRANCHID || '');
         $('#txtCOAdept').val(data.Department || '');
         $('#hdnCOADept').val(data.GL_DeptmtID || '');
         $('#txtCOACurrency').val(data.Currency || '');
         $('#hdnCOACurrencyId').val(data.Curncy_ID || '');

        $('#taxcode-select').val(data.TaxCode || '');

        // Add similar lines for any other fields you need to populate
    });

    function setRadio(group, value) {
        if (group === "GL_CLASS") {
            $('#GL_CLASS1').prop('checked', value === 'Revenue');
            $('#GL_CLASS2').prop('checked', value === 'Expense');
            $('#GL_CLASS3').prop('checked', value === 'Asset');
            $('#GL_CLASS4').prop('checked', value === 'Liability');
        } else {
            $('#' + group + '1').prop('checked', value === 'N');
            $('#' + group + '2').prop('checked', value === 'D');
            $('#' + group + '3').prop('checked', value === 'C');
            $('#' + group + '4').prop('checked', value === 'B');
        }
    }

    $(".form-switch input[type='checkbox']").on("change", function () {
        var $displayLabel = $(this).closest(".display-label");
        if ($(this).is(":checked")) {
            $displayLabel.removeClass("no").addClass("yes");
        } else {
            $displayLabel.removeClass("yes").addClass("no");
        }
    });

    // ✅ Separate save function — call this from onclick
        function saveGLCode() {

            $('#GL_BRANCHID').val($('#hdnCOAbranch').val());
            $('#GL_DeptmtID').val($('#hdnCOADept').val());
            $('#Curncy_ID').val($('#hdnCOACurrencyId').val());
        var formData = $('.glcode-form').serialize();
        console.log('Saving GL Code:', formData);

        $.ajax({
            url:'@Url.Action("SaveGLCode", "Home")',
            type:'POST',
            data:formData,
            dataType:'json',
            beforeSend: function () {
                // ✅ Disable button to prevent double submit
                $('.glcode-form').find('button[onclick="saveGLCode()"]')
                    .prop('disabled', true)
                    .text('Saving...');
            },
            success: function (response) {
                if (response.status) {
                    swalValidationAlert(response.message, "success").then(function () {
                        window.location.href = "@Url.Action("chart_of_accounts", "Home")"; // ✅ fixed typo: locationn → location
                    });
                } else {
                    swalValidationAlert(response.message, "error");
                }
            },
            error: function (xhr) {
                alert('Server error: ' + xhr.statusText);
            },
            complete: function () {
                // ✅ Re-enable button after request completes
                $('.glcode-form').find('button[onclick="saveGLCode()"]')
                    .prop('disabled', false)
                    .text('Save');
            }
        });
    }
</script>
    <script>
