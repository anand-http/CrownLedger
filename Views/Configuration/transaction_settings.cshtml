                                                                    <input type="number" class="form-control text-center py-1" placeholder="" aria-label="Search" aria-describedby="addon-wrapping" id="customerInvoiceDueDays" value="@(Model.TransactionSettings[0].CustomerInvoiceDueDays > 0 ? Model.TransactionSettings[0].CustomerInvoiceDueDays.ToString() :"")" />
