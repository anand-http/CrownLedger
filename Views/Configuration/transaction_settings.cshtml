       <input type="text" class="form-control aging_for_input text-center py-1"
              placeholder="" aria-label="Search" aria-describedby="addon-wrapping"
              id="vendorAgingTo${vendorRowCount}" value="${vendorToList[i]}">
   </div>`;

   // Append new rows
   $(".vendorFrom").append(newFromRow);
   $(".vendorTo").append(newToRow);
setupAutoFillVendor(vendorRowCount);
