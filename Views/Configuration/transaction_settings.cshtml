   // Save Transaction Settings
 function SaveTransactionSettings() {
     try {
         // Collect all customer aging rows dynamically
         var customerAgingFromArray = [];
         var customerAgingToArray = [];

         for (var i = 1; i <= customerRowCount; i++) {
             var fromVal = $('#customerAgingFrom' + i).val();
             var toVal = $('#customerAgingTo' + i).val();

             customerAgingFromArray.push(fromVal || '');
             customerAgingToArray.push(toVal || '');
         }

         // Collect all vendor aging rows dynamically
         var vendorAgingFromArray = [];
         var vendorAgingToArray = [];

         for (var i = 1; i <= vendorRowCount; i++) {
             var fromVal = $('#vendorAgingFrom' + i).val();
             var toVal = $('#vendorAgingTo' + i).val();

             vendorAgingFromArray.push(fromVal || '');
             vendorAgingToArray.push(toVal || '');
         }

         // Ensure we have at least 4 aging buckets for compatibility
         //while (customerAgingFromArray.length < 4) {
         //    customerAgingFromArray.push('');
         //}
         //while (customerAgingToArray.length < 4) {
         //    customerAgingToArray.push('');
         //}
         //while (vendorAgingFromArray.length < 4) {
         //    vendorAgingFromArray.push('');
         //}
         //while (vendorAgingToArray.length < 4) {
         //    vendorAgingToArray.push('');
         //}

         var customerSettings = {
             invoiceDueType: $('input[name="customerInvoiceDueType"]:checked').val(),
             invoiceDueDays: $('#customerInvoiceDueDays').val(),
             agingFrom: customerAgingFromArray || [],
             agingTo: customerAgingToArray || [],
             salesLedger: $('#hdncstmrSalesLedger').val(),
             discountLedger: $('#hdncstmrDiscountLedger').val()
         };

         var vendorSettings = {
             invoiceDueType: $('input[name="vendorInvoiceDueType"]:checked').val(),
             invoiceDueDays: $('#vendorInvoiceDueDays').val(),
             agingFrom: vendorAgingFromArray || [],
             agingTo: vendorAgingToArray || [],
             expenseLedger: $('#hdnvendorSalesLedger').val(),
             discountLedger: $('#hdnvendorDiscountLedger').val()
         };

         var paymentReceiptSettings = {
             otherReceiptLedger: $('#hdnotherReceiptLedger').val(),
             otherPaymentLedger: $('#hdnotherPaymentLedger').val(),
             customerReceiptDiscountLedger: $('#hdncstmrReceiptDiscountLedger').val(),
             vendorPaymentDiscountLedger: $('#hdnvendorPaymentDiscountLedger').val(),
             bankInterestReceivedLedger: $('#hdnBIReceivedLedger').val(),
             bankInterestChargesLedger: $('#hdnBIChargesLedger').val()
         };

         var productServiceSettings = {
             nonStockSalesAccount: $('#hdnNSSalesLedger').val(),
             nonStockExpenseAccount: $('#hdnNSExpenseLedger').val(),
             stockExpenseAccount: $('#hdnStExpenseLedger').val(),
             serviceSalesAccount: $('#hdnSSalesLedger').val(),
             serviceExpenseAccount: $('#hdnSExpenseLedger').val(),
             allowDuplicateItemNames: $('#allowDuplicateItemNames').is(':checked')
         };

         var accountingSettings = {
             showNegativeAssets: $('#hdnNegativeAssetsLedger').val()
         };

         var currencySettings = {
             enableMultiCurrency: $('#enableMultiCurrency').is(':checked')
         };

         // Validation
         if (!customerSettings.invoiceDueType) {
             Swal.fire({
                 icon: 'error',
                 title: 'Validation Error',
                 text: 'Please select Customer Invoice Due option'
             });
             return false;
         }

         if (customerSettings.invoiceDueType.includes('days') && !customerSettings.invoiceDueDays) {
             Swal.fire({
                 icon: 'error',
                 title: 'Validation Error',
                 text: 'Please enter number of days for Customer Invoice Due'
             });
             return false;
         }

         if (!vendorSettings.invoiceDueType) {
             Swal.fire({
                 icon: 'error',
                 title: 'Validation Error',
                 text: 'Please select Vendor Invoice Due option'
             });
             return false;
         }

         // Prepare request object
         var request = {
             customerSettings: customerSettings,
             vendorSettings: vendorSettings,
             paymentReceiptSettings: paymentReceiptSettings,
             productServiceSettings: productServiceSettings,
             accountingSettings: accountingSettings,
             currencySettings: currencySettings
         };

         // Show loading message
         Swal.fire({
             title: 'Saving...',
             text: 'Please wait while we save your settings',
             icon: 'info',
             allowOutsideClick: false,
             allowEscapeKey: false,
             didOpen: function () {
                 Swal.showLoading();
             }
         });

         // Make AJAX call
         $.ajax({
             url: '@Url.Action("SaveTransactionSettings", "Configuration")',
             type: 'POST',
             contentType: 'application/json',
             data: JSON.stringify(request),
             success: function (response) {
                 Swal.close();

                 if (response.Success) {
                     Swal.fire({
                         icon: 'success',
                         title: 'Success',
                         text: response.Message || 'Transaction settings saved successfully',
                         timer: 2000
                     }).then(function () {
                         location.reload();
                     });
                 } else {
                     Swal.fire({
                         icon: 'error',
                         title: 'Error',
                         text: response.message || 'Failed to save transaction settings'
                     });
                 }
             },
             error: function (xhr, status, error) {
                 Swal.close();

                 // Check for session expiration
                 if (xhr.status === 401) {
                     Swal.fire({
                         icon: 'warning',
                         title: 'Session Expired',
                         text: 'Your session has expired. Please login again.'
                     }).then(function () {
                         window.location.href = '@Url.Action("Index", "Login")';
                     });
                     return;
                 }

                 Swal.fire({
                     icon: 'error',
                     title: 'Error',
                     text: 'An error occurred while saving settings: ' + error
                 });
             }
         });

         return false;
     } catch (ex) {
         Swal.fire({
             icon: 'error',
             title: 'Error',
             text: 'An unexpected error occurred: ' + ex.message
         });
         return false;
     }
 }

var customerRowCount = 1;
var vendorRowCount = 1;
function setupAutoFillCustomer(rowNumber) {
    var fromId = 'customerAgingFrom' + rowNumber;
    var toId = 'customerAgingTo' + rowNumber;

    $('#' + fromId).on('input', function () {
        let value = parseInt($(this).val());
        if (value < 0) {
            return;
        }
        if (value === 0) {
            $('#' + toId).val(value + 30);
        } else if (!isNaN(value)) {
            $('#' + toId).val(value + 30 - 1);
        } else {
            $('#' + toId).val('');
        }
    });
}

function setupAutoFillVendor(rowNumber) {
            var fromId = 'vendorAgingFrom' + rowNumber;
            var toId = 'vendorAgingTo' + rowNumber;

            $('#' + fromId).off('input').on('input', function () {
                let value = parseInt($(this).val());

                if (!isNaN(value) && value === 0) {
                    $('#' + toId).val(value + 30);
                } else if (!isNaN(value)) {
                    $('#' + toId).val(value + 30 - 1);
                } else {
                    $('#' + toId).val('');
                }
            });
        }

if (customerRowCount === 1) {
    $("#btnDeleteCustomerRow").hide();
}
if (vendorRowCount === 1) {
    $("#btnDeleteVendorRow").hide();
        }

$('#customerAgingFrom1').on('input', function () {
            setupAutoFillCustomer(1);
        });

$('#vendorAgingFrom1').on('input', function () {
            setupAutoFillVendor(1);
});

