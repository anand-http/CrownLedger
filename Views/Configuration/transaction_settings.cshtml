            .removeClass('d-none')
            .css('display', 'inline-block');
    } else {
        $('#btnDeleteVendorRow')
            .css('display', 'none');
    }

});

// Delete vendor row
$("#btnDeleteVendorRow").click(function () {
            if (vendorRowCount > 1) {
                var fromRowId = 'vendorFromRow' + vendorRowCount;
                var toRowId = 'vendorToRow' + vendorRowCount;

                $('#' + fromRowId).remove();
                $('#' + toRowId).remove();

                vendorRowCount--;

                if (vendorRowCount === 1) {
                    $("#btnDeleteVendorRow").hide();
                }
            }
        });





















