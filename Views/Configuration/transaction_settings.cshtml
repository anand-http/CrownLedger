                                                                @(Model.TransactionSettings[0].CustomerInvoiceDueType == "Immediately" ? "checked" : "")>
                                                                <label class="form-check-label" for="payableinvoice4">Immediately</label>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
