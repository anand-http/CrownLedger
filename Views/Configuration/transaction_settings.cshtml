                                                                <label class="form-check-label" for="payableinvoice2">days after invoice date</label>
                                                            </div>
                                                            <div class="form-check form-check-inline">
                                                                <input class="form-check-input" type="radio" name="customerInvoiceDueType" id="payableinvoice3" value="End of next month"
