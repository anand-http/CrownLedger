                                            <h3 class="estimates-heading">Customers</h3>
                                            <div class="profile-item">
                                                <div class="row align-items-center g-0">
                                                    <div class="col-md-4">
                                                        <span class="profile-label">Invoice Due*</span>
                                                    </div>
                                                    <div class="col-md-8">
                                                        <div class="porfile-info-input-group">
                                                            <div class="form-check form-check-inline d-flex align-items-center">
                                                                <input class="form-check-input me-2" type="radio" name="customerInvoiceDueType" id="payableinvoice2" value="days after invoice date" 
