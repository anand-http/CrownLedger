    <div class="modal fade" id="addepartment" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="departmentForm">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalTitle">Add Department</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body" style="background:#fff;">
                        <input type="hidden" id="Deptmt_ID" name="Deptmt_ID" />
                        <div class="row g-3">
                            <div class="col-md-12">
                                <div class="form-floating" id="the-basics-agents">
                                    <input type="text" class="form-control" id="Deptmt_Code" name="Deptmt_Code" placeholder="Department Code" />
                                    <label for="Deptmt_Code">Department Code *</label>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="form-floating" id="the-basics-agents">
                                    <input type="text" class="form-control" id="Deptmt_Desc" name="Deptmt_Desc" placeholder="Department Name" />
                                    <label for="Deptmt_Desc">Department Name *</label>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <div class="form-group mb-0">
                                    <label class="form-label mb-1">Private <span title="Define private department Yes/No">&#9432;</span></label>
                                    <div class="d-flex align-items-center bg-white border rounded px-2 py-2" style="height:56px;">
                                        <div class="btn-group btn-group-toggle w-100" data-toggle="buttons">
                                            <label class="btn btn-outline-dark" style="width:48%;margin-right:4%;border-radius:6px;" id="privateNo">
                                                <input type="radio" name="Deptmt_Private" value="false" autocomplete="off" checked> No
                                            </label>
                                            <label class="btn btn-outline-dark" style="width:48%;border-radius:6px;" id="privateYes">
                                                <input type="radio" name="Deptmt_Private" value="true" autocomplete="off"> Yes
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-0">
                                    <label class="form-label mb-1">Group <span title="Define group department Yes/No">&#9432;</span></label>
                                    <div class="d-flex align-items-center bg-white border rounded px-2 py-2" style="height:56px;">
                                        <div class="btn-group btn-group-toggle w-100" data-toggle="buttons">
                                            <label class="btn btn-outline-dark" style="width:48%;margin-right:4%;border-radius:6px;" id="groupNo">
                                                <input type="radio" name="Deptmt_Group" value="false" autocomplete="off" checked> No
                                            </label>
                                            <label class="btn btn-outline-dark" style="width:48%;border-radius:6px;" id="groupYes">
                                                <input type="radio" name="Deptmt_Group" value="true" autocomplete="off"> Yes
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-0">
                                    <label class="form-label mb-1">Active <span title="Use this feature to activate/deactivate">&#9432;</span></label>
                                    <div class="d-flex align-items-center bg-white border rounded px-2 py-2" style="height:56px;">
                                        <div class="btn-group btn-group-toggle w-100" data-toggle="buttons">
                                            <label class="btn btn-outline-dark" style="width:48%;margin-right:4%;border-radius:6px;" id="activeNo">
                                                <input type="radio" name="Active" value="false" autocomplete="off" checked> No
                                            </label>
                                            <label class="btn btn-outline-dark" style="width:48%;border-radius:6px;" id="activeYes">
                                                <input type="radio" name="Active" value="true" autocomplete="off"> Yes
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
