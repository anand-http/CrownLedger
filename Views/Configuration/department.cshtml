});


        $('.search-input').on('keyup', function () {
            var value = this.value.trim();
            if (value.length >= 3 || value.length == 0) {
                DepartmentData.search(value).draw();
            }
        });


        $(document).on('change', '.isActive', function () {

            var isChecked = $(this).is(':checked');
            var row = $(this).closest('tr');
            var id = row.data('id');

         $.ajax({
             url: '@Url.Action("UpdateDepartment", "Configuration")',
             type: 'POST',
             data: { isChecked: isChecked, departmentId: id },
             success: function (res) {
             },
             error: function () {
                 alert('An error occurred while updating the status.');
             }
         });
        })

        $(document).on("click", ".delete-icon", function () {
         var row = $(this).closest('tr');
         var id = row.data('id');
         Swal.fire({
             icon: 'warning',
             title: 'Delete',
             text: "Are you sure you want to delete?",
             confirmButtonColor: '#d33'
         }).then(() => {
              $.ajax({
            url: '@Url.Action("UpdateDepartment", "Configuration")',
            type: 'POST',
                  data: { isChecked: true, departmentId: id, isDelete:true },
                  success: function (res) {
                      DepartmentData.draw();
            },
            error: function () {
                alert('An error occurred while updating the status.');
            }
       
           });
        })
      });


    function setRadioWithUI(name, value) {
        // uncheck all
        $('input[name="' + name + '"]').prop('checked', false);
        $('input[name="' + name + '"]').closest('label').removeClass('active');

        // check selected
        var selected = $('input[name="' + name + '"][value="' + value + '"]');
        selected.prop('checked', true);
        selected.closest('label').addClass('active');
        }
    $(document).ready(function () {
    // Open Add Modal
        $(document).on('click', '.add-customer', function () {
        $('#modalTitle').text('Add Department');
        $('#Deptmt_ID').val('');
        $('#Deptmt_Code').val('');
        $('#Deptmt_Desc').val('');
        $('input[name="Deptmt_Private"][value="false"]').prop('checked', true);
        $('input[name="Deptmt_Group"][value="false"]').prop('checked', true);
            $('input[name="Active"][value="false"]').prop('checked', true);
            setRadioWithUI('Active', "false");
            setRadioWithUI('Deptmt_Group', "false");
            setRadioWithUI('Deptmt_Private', "false");
        $('#addepartment').modal('show');
        });

       // Open Edit Modal
        $(document).on('click', '.edit-icon', function () {
        var deptId = $(this).data('id');
        var row = $(this).closest('tr');
        var code = row.find('td:eq(0)').text();
        var desc = row.find('td:eq(1)').text();
        var active = row.find('input[type="checkbox"]').is(':checked');
        var Deptmt_Group = row.find('.Deptmt_Group').val() === "true";
        var Deptmt_Private = row.find('.Deptmt_Private').val() === "true";

        $('#modalTitle').text('Edit Department');
        $('#Deptmt_ID').val(deptId);
        $('#Deptmt_Code').val(code);
        $('#Deptmt_Desc').val(desc);
        $('input[name="Active"][value="' + active + '"]').prop('checked', true);
        $('input[name="Deptmt_Group"][value="' + Deptmt_Group + '"]').prop('checked', true);
            $('input[name="Deptmt_Private"][value="' + Deptmt_Private + '"]').prop('checked', true);

            setRadioWithUI('Active', active.toString());
            setRadioWithUI('Deptmt_Group', Deptmt_Group.toString());
            setRadioWithUI('Deptmt_Private', Deptmt_Private.toString());
        $('#addepartment').modal('show');
        });

        

    // Save (Add/Edit)
    $('#departmentForm').submit(function (e) {
        e.preventDefault();
        var data = $(this).serialize();

        if (!validateField('Deptmt_Code', 'Please enter department code')) return;
        if (!validateField('Deptmt_Desc', 'Please enter department name')) return;

        $.post('@Url.Action("DepartmentAction", "Configuration")', data, function (response) {
            location.reload(); 
        });
    });
    });
        function validateField(fieldId, message) {
            if ($('#' + fieldId).val().trim() === '') {
                Swal.fire({
                    icon: 'warning',
                    title: 'Oops!',
                    text: message,
                    timer: 2000,
                    showConfirmButton: false
                });
                return false;
            }
            return true;
        }
        $(function () {
            $('input[name="fiscaldate"]').daterangepicker({
                singleDatePicker: true,
                showDropdowns: true,
                minYear: 1901,
                maxYear: parseInt(moment().format('YYYY'), 10)
            }, function (start, end, label) {
                var years = moment().diff(start, 'years');
            });
        });

        $(function () {
            $('input[name="daterange"]').daterangepicker(
                {
                    ssingleDatePicker: 'true',
                    showShortcuts: 'false',
                    showTopbar: 'false'
                }
            );
        });

        $('#datatable1').DataTable({
            "columnDefs": [
                {
                    "targets": -1,
                    "orderable": false
                }
            ],
            language: {
                search: "_INPUT_",
                searchPlaceholder: "Search..."
            },
            fixedHeader: {
                header: true,
            },
            "dom": '<"top"<"toolbar">tf<"clear">>rt<"bottom"lip<"clear">>'
        });

        $(".form-switch").click(function () {
            if ($(this).parent().hasClass("yes")) {
                $(this).parent().removeClass("yes");
                $(this).parent().addClass("no");
            } else {
                $(this).parent().removeClass("no");
                $(this).parent().addClass("yes");
            }
        });

    </script>

</body>
