// Save User Access
function SaveUserAccess() {
    // Validate form inputs
    var modalTitleText = $('#modalTitle').text().trim();
    var isEditMode = modalTitleText === 'Edit User Access';
    var userName = $('#inviteuser').find('#userName').val().trim();
    var email = $('#inviteuser').find('#email').val().trim();

    if (!userName) {
        Swal.fire({
            icon: 'error',
            title: 'Validation Error',
            text: 'User Name is required'
        });
        return false;
    }

    if (!email) {
        Swal.fire({
            icon: 'error',
            title: 'Validation Error',
            text: 'Email is required'
        });
        return false;
    }
    ``
    // Validate email format
    if (!IsValidEmail(email)) {
        Swal.fire({
            icon: 'error',
            title: 'Validation Error',
            text: 'Please enter a valid email address'
        });
        return false;
    }

    // Collect module access data
    var moduleAccess = [];
    var accessElements = $('#inviteuser').find('.access');

    accessElements.each(function (index) {
        var moduleName = $(this).find('.account-type').first().text().trim();
        var readCheckbox = $(this).find('input[type="checkbox"]').eq(0);
        var writeCheckbox = $(this).find('input[type="checkbox"]').eq(1);

        moduleAccess.push({
            ModuleDesc: moduleName,
            IsRead: readCheckbox.is(':checked'),
            IsWrite: writeCheckbox.is(':checked')
        });
    });


    //var hasAccess = moduleAccess.some(m => m.IsRead || m.IsWrite);
    //if (!hasAccess) {
    //    Swal.fire({
    //        icon: 'error',
    //        title: 'Validation Error',
    //        text: 'Please select at least one module access'
    //    });
    //    return false;
    //}

    // Prepare request object
    var request = {
        UserName: userName,
        Email: email,
        ModuleAccess: moduleAccess
    };

    // Make AJAX call
    $.ajax({
        url: '@Url.Action("SaveUserAccess", "Configuration")',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(request),
        success: function (response) {
            if (response.success) {
                if (!isEditMode) {
                   SendInvitationEmail(userName,email,moduleAccess);
                }
                ClearModalForm();
                var modal = bootstrap.Modal.getInstance(document.getElementById('inviteuser'));
                if (modal) {
                    modal.hide();
                }
                UserAccessData.draw();
                Swal.fire({
                    icon: 'success',
                    title: 'Success',
                    text: response.message,
                    timer: 2000
                })
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: response.message || 'Failed to save user access'
                });
            }
        },
        error: function (xhr, status, error) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'An error occurred while saving user access: ' + error
            });
        }
    });

    return false;
 }

 function SendInvitationEmail(userName,email,moduleAccess){
            var toEmail = email;
            var EmailSub = "Invitation to User Access";
            var accessHtml = "";

            moduleAccess.forEach(function (m) {
                var role = m.IsRead && m.IsWrite
                    ? "Full Access"
                    : m.IsRead
                        ? "Read Only"
                        : m.IsWrite
                            ? "Write Only"
                            : "No Access";

                accessHtml += `<tr>
        <td>${m.ModuleDesc}</td>
        <td>${role}</td>
    </tr>`;
            });

            var EmailBody = `
<p>Hi ${userName},</p>

<p>You have been granted access to the following modules:</p>

<table border="1" cellpadding="5" cellspacing="0">
    <tr>
        <th>Module</th>
        <th>Access</th>
    </tr>
    ${accessHtml}
</table>

<p>Regards,<br/>Team</p>
`;

   _showToast('Hang tight, we are sending your email...');
  _postAction({ toEmail: toEmail, EmailSub: EmailSub, EmailBody: EmailBody });
        }

 function _postAction(payload, onSuccess) {
            $.ajax({
                url: '@Url.Action("SendEmail", "Configuration")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                success: function (response) {
                    if (response.success) {
                        _showToast('Email sent successfully');
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Action Failed',
                            text: response.message || 'Something went wrong.'
                        });
                    }
                },
                error: function (xhr) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Server Error',
                        text: xhr.responseJSON && xhr.responseJSON.message
                            ? xhr.responseJSON.message
                            : xhr.statusText
                    });
                }
            });
        }

 function _showToast(msg) {
            if ($('#ieToast').length === 0) {
                $('body').append(
                    '<div id="ieToast" style="position:fixed;bottom:24px;right:24px;'
                    + 'background:#323232;color:#fff;padding:12px 20px;border-radius:6px;'
                    + 'z-index:9999;display:none;font-size:14px;"></div>'
                );
            }
            $('#ieToast').text(msg).fadeIn(200).delay(2500).fadeOut(400);
        }

        function IsValidEmail(email) {
    const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
    return emailRegex.test(email);
}

