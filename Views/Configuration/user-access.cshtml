    $('#modalTitle').text('Invite User');
}

     //Delete
     $(document).on("click", ".delete-icon", function () {
            var row = $(this).closest('tr');
            var id = row.data('id');
            Swal.fire({
                icon: 'warning',
                title: 'Delete',
                text: "Are you sure you want to delete?",
                showCancelButton: true,
                confirmButtonText: 'Yes',
                cancelButtonText: 'No',
                confirmButtonColor: '#6c757d',
                cancelButtonColor: '#d33'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteUser", "Configuration")',
                        type: 'POST',
                        data: { userId: id },
                        success: function (res) {
                            UserAccessData.draw();
                        },
                        error: function () {
                            alert('An error occurred while updating the status.');
                        }
                    });
                } else {
                    result.dismiss === Swal.DismissReason.cancel
                }

            })
     });

      //Edit - Get User Details
     $(document).on('click', '.edit-icon', function () {
         var row = $(this).closest('tr');
         var userId = row.data('id');

         if (!userId) {
             Swal.fire({
                 icon: 'error',
                 title: 'Error',
                 text: 'Invalid user ID'
             });
             return false;
         }

         // Make AJAX call to fetch user details
         $.ajax({
             url: '@Url.Action("GetUserAccessById", "Configuration")',
             type: 'POST',
             contentType: 'application/json',
             data: JSON.stringify({ userId: userId }),
             success: function (response) {
                 if (response.success) {
                     currentEditingUserId = userId;

                     $('#userName').val(response.data.userName || '');
                     $('#email').val(response.data.email || '');

                     $('#inviteuser').find('input[type="checkbox"]').prop('checked', false);

                     // Populate module access checkboxes
                     if (response.data.moduleAccess && response.data.moduleAccess.length > 0) {
                         response.data.moduleAccess.forEach(function (module) {
                             var accessElement = $('#inviteuser').find('.access').filter(function () {
                                 return $(this).find('.account-type').first().text().trim() === module.moduleDesc;
                             });

                             if (accessElement.length > 0) {
                                 // Check Read checkbox
                                 if (module.isRead) {
                                     accessElement.find('input[type="checkbox"]').eq(0).prop('checked', true);
                                 }
                                 // Check Write checkbox
                                 if (module.isWrite) {
                                     accessElement.find('input[type="checkbox"]').eq(1).prop('checked', true);
                                 }
                             }
                         });
                     }

                     // Update modal title
                     $('#modalTitle').text('Edit User Access');

                 } else {
                     Swal.fire({
                         icon: 'error',
                         title: 'Error',
                         text: response.message || 'Failed to fetch user details'
                     });
                 }
             },
             error: function (xhr, status, error) {
                 Swal.fire({
                     icon: 'error',
                     title: 'Error',
                     text: 'An error occurred while fetching user details: ' + error
                 });
             }
         });
     });


