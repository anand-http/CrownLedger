    <!-- ✅ Preview auto-update script -->
    <script>
        function updatePreview(id) {
            var prefix = $('#' + id + '_prefix').val() || '';
            var start = $('#' + id + '_start').val() || '';
            var preview = prefix || start ? (prefix + start) : '-';
            $('#' + id + '_preview').text(preview);
        }


  $(document).ready(function () {
    NumberSeriesTable = $("#numberseriestable").DataTable({
        "serverSide": true,
        "ajax": {
            "url": "@Url.Action("GetNumberSeriesList")",
            "type": "POST",
            "datatype": "json",
            "data": function (d) {
                d.icolelngth = 7;
            },
            "beforeSend": function () {
            },
            "complete": function () {
            }
        },
        createdRow: function (row, data, dataIndex) {
            $(row).attr('data-id', data.SeriesId);
        },
        "columns": [
            {
                // ── Column 1: Type Name ──
                "data": "TypeName",
                "name": "TypeName",
                "autoWidth": true,
                "visible": true,
                "render": function (data, type, row, meta) {
                    return `
                        <div class="d-flex align-items-center">
                            <div class="inputlabel d-flex align-items-center me-2">
                                <input class="form-check-input mt-0 row-check" type="checkbox" value="" id="chkSeries${meta.row}">
                            </div>
                            ${data ? data : ""}
                        </div>
                    `;
                }
            },
            {
                // ── Column 2: Prefix ──
                "data": "Prefix",
                "name": "Prefix",
